#include "hp_dialog_bluetooth.h"
#include "ui_hp_dialog_bluetooth.h"

hp_dialog_bluetooth::hp_dialog_bluetooth(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_dialog_bluetooth)
{
    ui->setupUi(this);
    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
    setWindowModality(Qt::WindowModal);
    //qDebug(" set ble ui finish");
    //    ui->frame->setStyleSheet("QWidget{background:black;}");
    ui->label_pariedDevice->close();
    ui->listWidget_pairedDevice->close();
    //    ui->label_bleStatus->close();
ui->frame->setStyleSheet("background-image: url(:/res/background_2.jpg);");
    ErrorWarning  = new hp_errorwarning_dialog(this);
    ErrorWarning->close();
    m_scanAddrNameMap.clear();

    ui->listWidget_availableDevice->setResizeMode(QListView::Adjust);      //设置单元项自适应
    ui->listWidget_availableDevice->setVerticalScrollBarPolicy(Qt::ScrollBarAlwaysOn);//设置滑动条是否显示
    QScroller *scroller=QScroller::scroller(ui->listWidget_availableDevice);
    scroller->grabGesture(ui->listWidget_availableDevice,QScroller::LeftMouseButtonGesture);//鼠标左键拖动
    ui->listWidget_availableDevice->setMovement(QListView::Static);//列表项不可被拖动

    currentSelect = Ble_LISTWIDGET;
    hp_updateStatus(true);

    currentBleMacAddr = "";
    currentBleName = "";
    isLongKey = false;
    isDisConnecting = false;
    isConnected = false;
    isConnecting = false;
    isSearch = false;
    ble_mode = false;

    BleStatusTimer = new QTimer(this);
    connect(BleStatusTimer,SIGNAL(timeout()),this,SLOT(SlotBleStatusTimer()));
    BleStatusTimer->setInterval(1000);
    //    qDebug(" set ble creat finish");
}

hp_dialog_bluetooth::~hp_dialog_bluetooth()
{
    delete ui;
}

void hp_dialog_bluetooth::changeEvent(QEvent *e)
{
    QWidget::changeEvent(e);
    switch(e->type())
    {
    case QEvent::LanguageChange:
        ui->retranslateUi(this);
        break;
    default:
        break;
    }
}

void hp_dialog_bluetooth::SlotSetUIStyle(int type)
{
    UIType = type;
    if(UIType == 1)
    {
        this->setGeometry(0,0,1920,1080);
        ui->frame->setGeometry(0,0,1920,1080);
        ui->listWidget_availableDevice->setGeometry(360,180,1152,675);
        ui->label_availableDevice->setGeometry(310,70,430,90);
        ui->label_pariedDevice->setGeometry(1790,50,180,41);
        ui->toolButton_search->setGeometry(160,645,360,67);
        ui->toolButton_disconnect->setGeometry(1080,645,360,67);
        ui->toolButton_close->setGeometry(68,68,68,68);
        ui->listWidget_pairedDevice->setGeometry(1830,100,350,300);
        ui->label_bleStatus->setGeometry(700,110,811,60);
        ui->label_bleSearchStatus->setGeometry(20,390,611,24);

        ui->toolButton_search->setStyleSheet(ToolButtonSheetStyle_1920_n);
        ui->toolButton_close->setStyleSheet(ToolButtonReturnSheetStyleBig_1920_n);
        ui->listWidget_availableDevice->setStyleSheet(ListWidgeVerticalSheetStyle_1920_n);
        ui->toolButton_disconnect->setStyleSheet(ToolButtonSheetStyle_1920_n);
        ui->frame->setStyleSheet("background-image: url(" UI_res_PATH_1920 "background_1.jpg);");
    }

}

void hp_dialog_bluetooth::keyPressEvent(QKeyEvent *ev)
{
    if(!(isLongKey=ev->isAutoRepeat()))
    {
        qDebug(" hp_dialog_bluetooth::keyPressEvent(QKeyEvent *ev)---------- ev->key() = 0x%02x",ev->key());
        SignalUpdateSetUpClock();
    }
    switch(ev->key())
    {
    default:
        break;
    }
}

void hp_dialog_bluetooth::keyReleaseEvent(QKeyEvent *ev)
{
    qDebug()<<" hp_dialog_bluetooth::keyReleaseEvent(QKeyEvent *ev)---------- ev->key() = "<<ev->key();
    switch (ev->key())
    {
    case Key_RETURN:
        KeyReturnHandle();
        break;
    case Key_CAPTURNANDVIDEO:
        SignalPrintscreenHandle();
        break;
    default:
        break;
    }
}

void hp_dialog_bluetooth::mousePressEvent(QMouseEvent *event)
{
    SignalUpdateSetUpClock();
}
//更新控件状态
void hp_dialog_bluetooth::hp_updateStatus(bool isSelect)
{
    switch (currentSelect) {
    case Ble_DISCONNECT:
        if(isSelect)
        {
            ui->toolButton_disconnect->setStyleSheet(ToolButtonSheetStyle_s);
        }
        else
        {
            ui->toolButton_disconnect->setStyleSheet(ToolButtonSheetStyle_n);
        }
        break;
    case Ble_LISTWIDGET:
        if(isSelect)
        {
            ui->listWidget_availableDevice->setStyleSheet(ListWidgeVerticalSheetStyle_s);
        }
        else
        {
            ui->listWidget_availableDevice->setStyleSheet(ListWidgeVerticalSheetStyle_n);
        }
        break;
    case Ble_RETURN:
        if(isSelect)
        {
            ui->toolButton_close->setStyleSheet(ToolButtonReturnSheetStyleBig_s);
        }
        else
        {
            ui->toolButton_close->setStyleSheet(ToolButtonReturnSheetStyleBig_s);
        }
        break;
    case Ble_SEARCH:
        if(isSelect)
        {
            ui->toolButton_search->setStyleSheet(ToolButtonSheetStyle_s);
        }
        else
        {
            ui->toolButton_search->setStyleSheet(ToolButtonSheetStyle_n);
        }
        break;
    }
}

//开启蓝牙
void hp_dialog_bluetooth::BleOn()
{
    hp_updateStatus(false);
    currentSelect = Ble_LISTWIDGET;
    hp_updateStatus(true);
    currentBleName = "";
    currentBleMacAddr = "";
    isConnected = false;
    isConnecting = false;
    on_toolButton_search_clicked();
    ui->listWidget_availableDevice->clear();
    ui->label_bleSearchStatus->clear();
    ui->label_bleStatus->clear();
    BleStatusTimer->start();
}
//关闭蓝牙
void hp_dialog_bluetooth::BleOff()
{
    MYLOG<<" isConnected : "<<isConnected;
    SignalSetIsBleConnected(false);
    if(isConnected)
    {
        on_toolButton_disconnect_clicked();
    }

    ui->label_bleStatus->close();
    ui->label_bleSearchStatus->clear();
//    on_toolButton_disconnect_clicked();
    BleStatusTimer->stop();
}
//搜索可使用蓝牙
void hp_dialog_bluetooth::on_toolButton_search_clicked()
{
    hp_updateStatus(false);
    currentSelect = Ble_SEARCH;
    hp_updateStatus(true);
    isSearch = true;
    qDebug()<<"hp_dialog_bluetooth::on_toolButton_search_clicked()";
    signal_pc_key_set_ble_search();
}
//选择蓝牙----使用列表
void hp_dialog_bluetooth::on_listWidget_availableDevice_itemPressed(QListWidgetItem *item)
{
    qDebug()<<"void hp_dialog_bluetooth::on_listWidget_availableDevice_itemPressed(QListWidgetItem *item)";
    hp_updateStatus(false);
    currentSelect = Ble_LISTWIDGET;
    hp_updateStatus(true);

    char bleMacAddr[50];
    memset(bleMacAddr,0,sizeof(bleMacAddr));
    currentBleName = item->text().split("(").at(0);
    currentBleMacAddr = item->text().split("(").at(1);
    currentBleMacAddr.chop(1);
    char *cBleMaxAddr = currentBleMacAddr.toUtf8().data();
    memcpy(bleMacAddr,cBleMaxAddr,strlen(cBleMaxAddr));

    qDebug()<<" currentBleName "<<currentBleName;
    qDebug()<<" currentBleMacAddr : "<<currentBleMacAddr;
    printf("send to  core  :%s\n",bleMacAddr);

    isConnecting = true;
    QString strblelabletext = tr("蓝牙连接中 : ") + currentBleName + "(" + currentBleMacAddr + ")";
    ui->label_bleStatus->setText(strblelabletext);
    ui->label_bleStatus->show();
    signal_pc_key_set_ble_connect(bleMacAddr);
}
//选择蓝牙----已匹配列表
void hp_dialog_bluetooth::on_listWidget_pairedDevice_itemPressed(QListWidgetItem *item)
{
}
//点击断开蓝牙
void hp_dialog_bluetooth::on_toolButton_disconnect_clicked()
{
    hp_updateStatus(false);
    currentSelect = Ble_DISCONNECT;
    hp_updateStatus(true);
    isDisConnecting = true;
    MYLOG<<" isConnected : "<<isConnected;
    SignalSetIsBleConnected(false);

    if(currentBleMacAddr == "")
    {
        signal_pc_key_get_ble_devinfo();
        return;
    }

    char bleMacAddr[50];
//    currentBleMacAddr = m_scanAddrNameMap.key(currentBleName);
    char *cBleMaxAddr = currentBleMacAddr.toUtf8().data();
    memcpy(bleMacAddr,cBleMaxAddr,strlen(cBleMaxAddr));

    qDebug()<<" currentBleMacAddr : "<<currentBleMacAddr;
    printf("send to  core  :%s\n",bleMacAddr);

    signal_pc_key_set_ble_disconnect(cBleMaxAddr);
}
