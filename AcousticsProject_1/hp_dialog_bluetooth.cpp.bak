//定时查询蓝牙状态
void hp_dialog_bluetooth::SlotBleStatusTimer()
{
    signal_pc_key_get_ble_state();
}
//获取蓝牙耳机搜索结果
void hp_dialog_bluetooth::slot_pc_key_get_ble_search(unsigned char return_value, char *data)
{
    qDebug(" hp_dialog_bluetooth::slot_pc_key_get_ble_search(unsigned char return_value : 0x%02x",return_value);

    ui->listWidget_availableDevice->clear();
    if(return_value == RE_OK)
    {
        QString strNames = QString::fromUtf8(data);
        int Itemnum = 0;
        QStringList strs = strNames.split("\n");
        qDebug()<<"strNames"<<strNames<<"  strs.length() : "<<strs.length();
        if(strs.count() == 0)
            return;

        //        for(QString addrName : strs)
        //        {
        //            if(addrName.split(",").count() < 2)
        //                break;
        //            QString mac_addr = addrName.split(",").at(0);
        //            QString dev_name = addrName.split(",").at(1);
        //            m_scanAddrNameMap.insert(mac_addr, dev_name);
        //            qDebug() << "mac_addr" << mac_addr << "dev_name" << dev_name;
        //        }

        m_scanAddrNameMap.clear();
        for(QString addrName : strs)
        {
            qDebug() << "add new ble";
            if(addrName.split(",").count() < 2)
                break;
            QString mac_addr = addrName.split(",").at(0);
            QString dev_name = addrName.split(",").at(1);
            m_scanAddrNameMap.insert(mac_addr, dev_name);//key为地址 value为名字
            qDebug() << "mac_addr" << mac_addr << "dev_name" << dev_name;
        }
        QMap<QString, QString>::const_iterator itMap = m_scanAddrNameMap.constBegin();
        for(; itMap != m_scanAddrNameMap.constEnd(); itMap++)
        {
            QString bleItem_name = itMap.value();
            QString bleItem_addr = itMap.key();
            ui->listWidget_availableDevice->addItem(bleItem_name + "(" + bleItem_addr + ")");
        }
    }
}
