//获取连接的蓝牙
void hp_dialog_bluetooth::slot_pc_key_get_ble_devinfo(unsigned char return_value,char *data)
{
    if(!ble_mode)
        return;
    qDebug("hp_dialog_bluetooth::slot_pc_key_get_ble_devinfo(unsigned char return_value : 0x%02x",return_value);
    QString strNames = QString::fromUtf8(data);
    if(strNames == NULL)
        return;
    qDebug()<<"slot_pc_key_get_ble_devinfo ------strNames : "<<strNames;

    QString mac_addr = strNames.split(",").at(0);
    QString dev_name = strNames.split(",").at(1);
    m_scanAddrNameMap.insert(mac_addr, dev_name);
    currentBleMacAddr = mac_addr;
    currentBleName = dev_name;

    if(isDisConnecting)
    {
        on_toolButton_disconnect_clicked();
        return;
    }

    QString strblelabletext;
    strblelabletext = tr("蓝牙已连接 : ") + currentBleName + "(" + currentBleMacAddr + ")";
    ui->label_bleStatus->setText(strblelabletext);
    ui->label_bleStatus->show();
}
//断开蓝牙反馈
void hp_dialog_bluetooth::slot_pc_key_set_ble_disconnect(unsigned char return_value)
{
    if(ble_mode)
    {
        qDebug()<<"hp_dialog_bluetooth::slot_pc_key_set_ble_disconnect return_value : "<<return_value<<"BleName : "<<currentBleName;
        isDisConnecting = false;
    }
}
//static int g_ble_scan_state = 0;/*蓝牙扫描状态 -1-异常 0-初始化 1-开始扫描 2-正在扫描 3-扫描完成*/
//static  int conn_state;/*0-断开连接 1-正在连接 2-已连接*/
//static int g_ble_pair_state = 0;/*蓝牙配对信息状态 -1-异常 0-初始化 1-开始读取 2-开始清除 3-正在读取 4-读取完成 5-清除成功*/
//获取蓝牙状态
void hp_dialog_bluetooth::slot_pc_key_get_ble_state(unsigned char return_value,ble_stat bleStat)
{
    if(!ble_mode)
        return;
//    qDebug("hp_dialog_bluetooth::slot_pc_key_get_ble_state(unsigned char return_value : 0x%02x ",return_value);
    QString strblelabletext;
    //连接状态
    qDebug()<<"hp_dialog_bluetooth:: ble state Connect : "<<bleStat.a2dpStat<<" ble search state  : "<<bleStat.scanStat<< " isSearch : "<<isSearch<<"isConnected : "<<isConnected;
    switch (bleStat.a2dpStat) {
    case 0://断开连接
        MYLOG<<" isConnected : "<<isConnected;
        SignalSetIsBleConnected(false);
        ui->label_bleStatus->close();
        isConnecting = false;
        isConnected = false;
        break;
    case 1://正在连接
        isConnecting = true;
        isConnected = false;
        MYLOG<<" isConnected : "<<isConnected;
        SignalSetIsBleConnected(false);
        strblelabletext = tr("蓝牙连接中 : ") + currentBleName + "(" + currentBleMacAddr + ")";
        ui->label_bleStatus->setText(strblelabletext);
        ui->label_bleStatus->show();
        break;
    case 2://连接完成
        if(!isConnected)
        {
            if(currentBleName == "" )
            {
                signal_pc_key_get_ble_devinfo();
            }
            strblelabletext = tr("蓝牙已连接 : ") + currentBleName + "(" + currentBleMacAddr + ")";
            ui->label_bleStatus->setText(strblelabletext);
            ui->label_bleStatus->show();
            isConnecting = false;
            isConnected = true;
            MYLOG<<" isConnected : "<<isConnected;
            SignalSetIsBleConnected(true);
        }
        break;
    default:
        isConnected = false;
        break;
        //    default:
        //        break;
    }
    //扫描状态
//    qDebug()<<" ble search state  : "<<bleStat.scanStat<< " isSearch : "<<isSearch;
    if(isSearch)
    {
        switch (bleStat.scanStat) {
        case -1://异常
            ui->label_bleSearchStatus->setText(tr("请再次搜索..."));
            break;
        case 0://初始化
            ui->label_bleSearchStatus->clear();
            break;
        case 1://开始扫描
        case 2://正在扫描
            ui->label_bleSearchStatus->setText(tr("蓝牙搜索中..."));
            break;
        case 3://扫描完成
            isSearch = false;
            ui->label_bleSearchStatus->setText(tr("蓝牙搜索完成"));
            signal_pc_key_get_ble_search();
            break;
        default:
            break;
        }
    }

    //
//    qDebug()<<" ble pairStat state  : "<<bleStat.pairStat;
    //    switch (bleStat.scanStat) {
    //    case -1://异常
    //        ui->label_bleSearchStatus->setText(tr("请再次搜索..."));
    //        break;
    //    case 0://初始化
    //        ui->label_bleSearchStatus->clear();
    //        break;
    //    case 1://开始扫描
    //    case 2://正在扫描
    //        ui->label_bleSearchStatus->setText(tr("蓝牙搜索中..."));
    //        break;
    //    case 3://扫描完成
    //        ui->label_bleSearchStatus->setText(tr("蓝牙搜索完成"));
    //        signal_pc_key_get_ble_search();
    //        break;
    //    default:
    //        break;
    //    }
}
//设置是否连接提示
void hp_dialog_bluetooth::hp_setLableBleStatus(int type)
{
    switch(type)
    {
    case 0://未连接
    case 1://连接中
    case 2://已连接
        break;
    default:
        break;
    }
}
//关闭蓝牙设置界面
void hp_dialog_bluetooth::on_toolButton_close_clicked()
{
    this->close();
}
//按键 ↓键
void hp_dialog_bluetooth::KeyDownHandle()
{
    hp_updateStatus(true);
    if(currentSelect == Ble_LISTWIDGET)
    {
        currentSelect = Ble_SEARCH;
    }
    else if(currentSelect == Ble_RETURN)
    {
        currentSelect = Ble_LISTWIDGET;
    }
    hp_updateStatus(true);
}
//按键 ↑键
void hp_dialog_bluetooth::KeyUpHandle()
{
    hp_updateStatus(false);
    switch (currentSelect) {
    case Ble_DISCONNECT:
        currentSelect = Ble_LISTWIDGET;
        break;
    case Ble_LISTWIDGET:
        currentSelect = Ble_RETURN;
        break;
    case Ble_RETURN:
        break;
    case Ble_SEARCH:
        currentSelect = Ble_LISTWIDGET;
        break;
    }
    hp_updateStatus(true);
}
//按键 ←键
void hp_dialog_bluetooth::KeyLeftHandle()
{
    hp_updateStatus(false);
    if(currentSelect == Ble_DISCONNECT)
    {
        currentSelect = Ble_SEARCH;
    }
    hp_updateStatus(true);
}
//按键 →键
void hp_dialog_bluetooth::KeyRightHandle()
{
    hp_updateStatus(false);
    if(currentSelect==Ble_SEARCH) {
        currentSelect = Ble_DISCONNECT;
    }
    hp_updateStatus(true);
}
//按键 确认键
void hp_dialog_bluetooth::KeyOKHandle()
{
    switch (currentSelect) {
    case Ble_DISCONNECT:
        emit ui->toolButton_disconnect->clicked();
        break;
    case Ble_LISTWIDGET:
        if(ui->listWidget_availableDevice->count() == 0)
        {
            return;
        }
        emit ui->listWidget_availableDevice->itemPressed(ui->listWidget_availableDevice->currentItem());
        break;
    case Ble_RETURN:
        emit ui->toolButton_close->clicked();
        break;
    case Ble_SEARCH:
        emit ui->toolButton_search->clicked();
        break;
    }
}
//按键 返回键
void hp_dialog_bluetooth::KeyReturnHandle()
{
    emit ui->toolButton_close->clicked();
}
