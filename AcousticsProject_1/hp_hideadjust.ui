	border:0px solid #bbb;
}

QSlider::sub-page:horizontal{          /*进度条左边*/
	background-color:rgb(0, 221, 253);
	border-radius:2px;
	margin-top:9px;
	margin-bottom:9px;
}
QSlider::add-page:horizontal{       /*进度条右边*/
	background:gray;
	border:0px solid #777;
	border-radius:2px;
	margin-top:7px;
	margin-bottom:7px;
}
QSlider::handle:horizontal{         /*滑块*/
	border:0px solid white;
	
	background-color: rgb(85, 255, 255);
	border-radius:0px;
	width: 20px;
	margin-top:3px;
	margin-bottom:3px;
}</string>
