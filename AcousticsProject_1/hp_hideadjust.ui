    <string notr="true">
QScrollBar:vertical{    
width:30px;/*整个滑动条的宽度*/
background:rgb(45, 48, 51);
border:none;
margin:00px 0px 00px 0px;/*上下两个小方块的长宽 也控制滑动条宽度*/
}

QScrollBar:horizontal{    
height:30px;/*整个滑动条的宽度*/
background:rgb(45, 48, 51);
border:none;
margin:0px 0px 0px 0px;/*上下两个小方块的长宽 也控制滑动条宽度*/
}

QScrollBar::handle:vertical{
background:rgb(85, 255, 255);/*中间滑块的颜色*/
border:none;
border-radius:3px;
}

QScrollBar::handle:horizontal{
background:rgb(85, 255, 255);/*中间滑块的颜色*/
border:none;
border-radius:3px;
}

QScrollBar::add-line:vertical {
width: 3px;
background:rgb(22, 24, 26);
border:none;
subcontrol-position:right;
subcontrol-origin:margin;
}

QScrollBar::add-line:horizontal {
width: 3px;
background:rgb(22, 24, 26);
border:none;
subcontrol-position:right;
subcontrol-origin:margin;
}

QScrollBar::sub-line:vertical {
border:none;
background:rgb(22, 24, 26);
width: 3px;
subcontrol-origin:margin;
subcontrol-position:left;
}

QScrollBar::sub-line:horizontal {
border:none;
background:rgb(22, 24, 26);
width: 3px;
subcontrol-origin:margin;
subcontrol-position:left;
}

QScrollBar::top-arrow:vertical{
subcontrol-origin: margin;
height:3px;
width:3px;
border:0px solid rgb(45, 48, 51);
background:rgb(45, 48, 51);
}


QScrollBar::bottom-arrow:vertical{
subcontrol-origin: margin;
height:3px;
width:3px;
border:0px solid rgb(45, 48, 51);
background:rgb(45, 48, 51);
}
QScrollBar::sub-page:vertical{
background:black;
}
QScrollBar::add-page:vertical
{
background:black;
}</string>
