bool hp_gradient_rect::eventFilter(QObject *obj, QEvent *event)
{
    if(event->type() == QMouseEvent::MouseButtonPress)
    {
        if(obj->objectName()=="label_min")
        {
            qDebug("label_min");
            isSliderShow=!isSliderShow;
//            update();
        }
    }
    return false;
}
