#include "hp_gradient_rect.h"
#include "ui_hp_gradient_rect.h"

hp_gradient_rect::hp_gradient_rect(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_gradient_rect)
{
    ui->setupUi(this);

    isSliderShow=0;
    isPress= false;
    //    ui->verticalSlider->close();

    ui->label_max->close();
    ui->label_min->close();

    moving_range.lower = 0;
    movingRangeMaxValue = 1000;
    moving_range.upper=1000;
    ui->verticalSlider->setMaximum(1000);
    ui->verticalSlider->setMinimum(0);
    ui->label_min->installEventFilter(this);
    ui->verticalSlider->installEventFilter(this);
}

hp_gradient_rect::~hp_gradient_rect()
{
    delete ui;
}
