//更改动态范围最大值
void hp_gradient_rect::hp_setMovingRangeUpper(int movingRangeUpper)
{
    movingRangeMaxValue=1000;
    ui->label_max->setText(QString::number(movingRangeUpper)+"dB");
}
//更改动态范围最小值
void hp_gradient_rect::hp_setMovingRangeLower(int_move_range value)
{
    moving_range = value;
    moving_range.lower=Limit(value.lower,moving_range.upper,0);
    qDebug()<<"moving_range.lower : "<<moving_range.lower<<"QString::number(moving_range.lower)"<<QString::number(moving_range.lower);
    ui->label_min->setText(QString::number(moving_range.lower)+"dB");
    ui->verticalSlider->setValue(value.lower);
    on_verticalSlider_sliderReleased();
}
//进度条松开事件
void hp_gradient_rect::on_verticalSlider_sliderReleased()
{
    int value = ui->verticalSlider->value();
    moving_range.lower=value;
    signal_pc_key_set_moving_range(moving_range);
    ui->label_min->setText( QString::number(value)+"dB");
    if(isPress)
    {
        isPress=false;
        hp_undateSliderUI(false);
        SignalSetDynamicRange(moving_range);
    }
}
//进度条是否选中状态更新
void hp_gradient_rect::hp_undateSliderUI(bool isSelect)
{
    if(isSelect)
    {
        ui->verticalSlider->setStyleSheet("QSlider::groove:vertical{border:0px solid #ffffff;}\
                                           QSlider::sub-page:vertical{background-color:rgb(178, 180, 181);border-radius:0px;}\
                                           QSlider::add-page:vertical{background-color:rgb(0, 221, 253);border:0px solid #777;border-radius:0px;}\
                                           QSlider::handle:vertical{ border:0px solid white; background:#ffffff;\
                                                                     border-radius:0px;height: 20px; margin-top:0px;margin-bottom:0px;}");
    }
    else
    {
        ui->verticalSlider->setStyleSheet("QSlider::groove:vertical{border:0px solid #ffffff;}\
                                           QSlider::sub-page:vertical{background-color:gray;border-radius:0px;}\
                                           QSlider::add-page:vertical{background-color:gray;border:0px solid #777;border-radius:0px;}\
                                           QSlider::handle:vertical{ border:0px solid white; background:#ffffff;\
                                                                    border-radius:0px;height: 20px; margin-top:0px;margin-bottom:0px;}");
    }
}
//进度条按下事件
void hp_gradient_rect::on_verticalSlider_sliderPressed()
{
    isPress = true;
    hp_undateSliderUI(true);
//    SignalGradientRectPressed();
}
