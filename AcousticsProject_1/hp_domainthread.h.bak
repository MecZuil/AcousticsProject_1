    void signal_pc_key_set_twozoom(unsigned char return_value);
    void signal_pc_key_set_autozoom(unsigned char return_value);
    void signal_pc_key_set_displaypos(unsigned char reutrn_value);
    void signal_pc_key_set_irstream(unsigned char return_value);
