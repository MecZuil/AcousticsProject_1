#define SDBLK_PATH			"/dev/mmcblk2"							//总设备节点
#define SDDEV_PATH			"/dev/mmcblk2p1"						//SD卡所在分区
#define SDMOUNT_PATH		"/run/media/mmcblk2p1"					//SD卡挂载路径
#define SDSAVE_PATH			"/run/media/mmcblk2p1/DCIM"				//SD卡保存路径

#define SDMOUNT_CMD			"mount -t vfat -o noatime -o nodiratime /dev/mmcblk2p1 /run/media/mmcblk2p1 -o umask=0000"	//SD卡挂载命令
#define SDUMOUNT_CMD		"umount -l /run/media/mmcblk2p1"		//SD卡卸载命令
#define SDMKDIRSAVE_CMD		"mkdir -p /run/media/mmcblk2p1/DCIM"	//创建SD卡保存目录
#define SDFORMAT_CMD		"mkfs.vfat /dev/mmcblk2p1"				//格式化SD卡分区
#define SDDELETEALL_CMD		"rm /run/media/mmcblk2p1/* -rf"			//删除SD卡分区里所有文件

#define RESET_CONFIG_XML_CMD            "cp /home/root/config_default.xml /home/root/config.xml"
#define RESET_ENC_XML_CMD               "cp /home/root/enc_default.xml /home/root/enc.xml"
#define RESET_SYS_XML_CMD               "cp /home/root/sys_default.xml /home/root/sys.xml"

#define _ABS(a) ((a) < 0 ? -(a) : (a))
#define SWAP(a, b) do { (a) = (a) ^ (b); \
    (b) = (a) ^ (b); \
    (a) = (a) ^ (b); \
    } while (0)

#define AVI_FRAME           14		//录像帧率
#define SDFORMAT_CMD		"mkfs.vfat /dev/mmcblk2p1"				//格式化SD卡分区


class hp_domainthread : public QThread
