#include "hp_display_fdp.h"
#include "ui_hp_display_fdp.h"

#define isDebug 0

hp_display_fdp::hp_display_fdp(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_display_fdp)
{
    ui->setupUi(this);


    hp_winInit();
    hp_plotStyleInit();
    TimerFDP = new QTimer(this);
    connect(TimerFDP,SIGNAL(timeout()),this,SLOT(SlotDataCount()));
    TimerFDP->setInterval(5000);//5s读取帧率
    //        connect(TimerFDP,SIGNAL(timeout()),this,SLOT(hp_plotDataShow()));
    //        TimerFDP->setInterval(80);//自测

    TimerFDP->start();
}

hp_display_fdp::~hp_display_fdp()
{
    delete ui;
}

void hp_display_fdp::SlotSetUIStyle(int type)
{
    UIType = type;
    if(type == 1)
    {
        QFont font("Microsoft YaHei", 20);
        this->setGeometry(0,0,1920,1080);
        ui->plot->setGeometry(0,0,216,1080);
        ui->chooseRect->setGeometry(0,260,216,203);
        ui->label_max->setGeometry(59,0,101,39);
        ui->label_min->setGeometry(70,170,91,31);
        ui->label_max->setFont(font);
        ui->label_min->setFont(font);
    }
}

void hp_display_fdp::hp_winInit()
{
    //qcustomplot类提升后,触摸事件需要自行连接信号
    connect(ui->plot,&QCustomPlot::mousePress,this,&hp_display_fdp::mousePressEvent);
    connect(ui->plot,&QCustomPlot::mouseMove,this,&hp_display_fdp::mouseMoveEvent);
    connect(ui->plot,&QCustomPlot::mouseRelease,this,&hp_display_fdp::mouseReleaseEvent);

    this->setStyleSheet("background-color: rgb(95,95,95);");
    chooseBottomLine=false;
    chooseTopLine=false;
    chooseMoveRect=false;
    isAdaptiveOpen = false;
    isSLMOpen = false;
    is10KSetEnabled = false;
    f=value_Max / poordX_Max;   //实际数据2048 / 显示轴坐标100
    cyRatio = value_Max/poordY_Max; //实际数据2048 / y轴480
    valuePlot = 0;
    dataCount = 0;
    y_topLine = 0;
    y_buttonLine = 0;
    tickOffset = 15;
    isChangePingDuan = 0;

    QString Para;
    Para = XmlReader.ReadXml("qtconfig.xml","FREQ_RANGE","is10k_set");
    is10KSetEnabled = false;
    if(Para != NULL)
    {
        if(Para.toInt() == 1)
        {
            is10KSetEnabled = true;
        }
    }

}
