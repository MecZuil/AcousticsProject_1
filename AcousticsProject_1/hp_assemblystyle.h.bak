#define FrameSheetStyle_s "QFrame{background:transparent; border:1px solid " FrameBorderColor_s "; border-radius:3px;}"

#define FrameSheetStyle_n "QFrame{background:transparent; border:1px solid " FrameBorderColor_n " ; border-radius:3px;}"

#define ListWidgetHorizontalSheetStyle_s "QListWidget{background:#000000;color:#ffffff;border:0px solid grey;}\
QListView::item:selected{background:grey;border:1px solid " FrameBorderColor_s "; }\
QListView::item:selected:!active{border:1px solid rgb(0, 221, 253);background:grey;}\
QScrollBar:horizontal{ height:3px;background: #16181a;border:none;margin:0px 3px 0px 3px;}\
QScrollBar::handle:horizontal{background:rgb(0, 221, 253);border:none;min-width:3px;border-radius:1px;}\
QScrollBar::add-line:horizontal {width: 0px;background:black; border:none;subcontrol-position:right;subcontrol-origin:margin;}\
QScrollBar::sub-line:horizontal { width: 0px;background:black;border:none;subcontrol-position:left;subcontrol-origin:margin;}\
QScrollBar::sub-page:horizontal{background:black; }\
QScrollBar::add-page:horizontal{background:black;}"

#define ListWidgetHorizontalSheetStyle_n "QListWidget{background:#000000;color:#ffffff;border:0px solid grey;}\
                                          QListView::item:selected{background:grey;border:0px solid " FrameBorderColor_s "; }\
                                          QListView::item:selected:!active{border:0px solid  " FrameBorderColor_s " ;background:grey;}\
                                          QScrollBar:horizontal{ height:3px;background: #16181a;border:none;margin:0px 3px 0px 3px;}\
                                          QScrollBar::handle:horizontal{background: " FrameBorderColor_s " ;border:none;min-width:3px;border-radius:1px;}\
                                          QScrollBar::add-line:horizontal {width: 0px;background:black; border:none;subcontrol-position:right;subcontrol-origin:margin;}\
                                          QScrollBar::sub-line:horizontal { width: 0px;background:black;border:none;subcontrol-position:left;subcontrol-origin:margin;}\
                                          QScrollBar::sub-page:horizontal{background:black; }\
                                          QScrollBar::add-page:horizontal{background:black;}"

#define ListWidgeVerticalSheetStyle_s  "QListWidget{background:transparent;border:1px solid " FrameBorderColor_s ";}\
                                          QAbstractItemView {background-color:#000000;color:#ffffff;border:1px solid " FrameBorderColor_s ";border-radius:3px;}\
                                          QAbstractItemView::item:selected {color: #ffffff;background-color: " FrameBorderColor_s " ;}\
                                          QScrollBar:vertical{width:3px;background:rgb(45, 48, 51);border:none;margin:3px 0px 3px 0px;}\
                                          QScrollBar::handle:vertical{background: " FrameBorderColor_s " ;border:none;border-radius:3px;}\
                                          QScrollBar::add-line:vertical {width: 3px;background:rgb(22, 24, 26);border:none;subcontrol-position:right;subcontrol-origin:margin;}\
                                          QScrollBar::sub-line:vertical {border:none;background:rgb(22, 24, 26);width: 3px;subcontrol-origin:margin;subcontrol-position:left;}\
                                          QScrollBar::top-arrow:vertical{subcontrol-origin: margin;height:3px;width:3px;border:0px solid rgb(45, 48, 51);background:rgb(45, 48, 51);}\
                                          QScrollBar::bottom-arrow:vertical{subcontrol-origin: margin;height:3px;width:3px;border:0px solid rgb(45, 48, 51);background:rgb(45, 48, 51);}\
                                          QScrollBar::sub-page:vertical{background:black;}QScrollBar::add-page:vertical{background:black;}"

#define ListWidgeVerticalSheetStyle_n  "QListWidget{background:transparent;border:1px solid " FrameBorderColor_n ";}\
                                          QAbstractItemView {background-color:#000000;color:#ffffff;border:1px solid rgb(255,255,255);border-radius:3px;}\
                                          QAbstractItemView::item:selected {color: #ffffff;background-color: " FrameBorderColor_s " ;}\
                                          QScrollBar:vertical{width:3px;background:rgb(45, 48, 51);border:none;margin:3px 0px 3px 0px;}\
                                          QScrollBar::handle:vertical{background: " FrameBorderColor_s ";border:none;border-radius:3px;}\
                                          QScrollBar::add-line:vertical {width: 3px;background:rgb(22, 24, 26);border:none;subcontrol-position:right;subcontrol-origin:margin;}\
                                          QScrollBar::sub-line:vertical {border:none;background:rgb(22, 24, 26);width: 3px;subcontrol-origin:margin;subcontrol-position:left;}\
                                          QScrollBar::top-arrow:vertical{subcontrol-origin: margin;height:3px;width:3px;border:0px solid rgb(45, 48, 51);background:rgb(45, 48, 51);}\
                                          QScrollBar::bottom-arrow:vertical{subcontrol-origin: margin;height:3px;width:3px;border:0px solid rgb(45, 48, 51);background:rgb(45, 48, 51);}\
                                          QScrollBar::sub-page:vertical{background:black;}QScrollBar::add-page:vertical{background:black;}"

