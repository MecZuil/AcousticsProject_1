#define SPINBOX_DATESETTING_n "QSpinBox{font: 12pt ;background:transparent;color:white;border:0px solid " FrameBorderColor_n " ;}\
                                QSpinBox::up-button { width: 25; height: 30; }QSpinBox::down-button {width: 25;height: 30;}"

#define SPINBOX_DATESETTING_s "QSpinBox{font: 12pt ;background:transparent;color:white;border:1px solid " FrameBorderColor_s ";}\
                                QSpinBox::up-button { width: 25; height: 30; }QSpinBox::down-button {width: 25;height: 30;}"


