#define CheckBoxSheetStyle_n "QCheckBox{background:transparent;}\
QCheckBox::indicator:unchecked {image: url(:/res/checkBox_n.png);color: " CheckBoxTextFontColor ";}\
QCheckBox::indicator:checked {image: url(:/res/checkBox_s.png);color: " CheckBoxTextFontColor ";}\
QCheckBox::indicator:disabled { image: url(:/res/checkBox_d.png);color: " CheckBoxTextFontColor "; }"

#define CheckBoxSheetStyle_s "QCheckBox{background:transparent;color: " CheckBoxTextFontColor ";border:1px solid " FrameBorderColor_s "; border-radius:3px;}\
QCheckBox::indicator:unchecked {image: url(:/res/checkBox_n.png);color: " CheckBoxTextFontColor ";}\
QCheckBox::indicator:checked { image: url(:/res/checkBox_s.png);color: " CheckBoxTextFontColor ";}\
QCheckBox::indicator:disabled {image: url(:/res/checkBox_d.png);color: " CheckBoxTextFontColor ";}"

#define ToolButtonSheetStyle_s "QToolButton{background:transparent;border-image: url(:/res/label_Background_s.png);color:" CheckBoxTextFontColor " ;}\
QToolButton::pressed{background:transparent;border-image: url(:/res/label_Background_s.png);color: " CheckBoxTextFontColor ";}\
QToolButton::disabled{background:transparent;border-image: url(:/res/label_Background_d.png);color:white;}"

