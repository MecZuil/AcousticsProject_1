#define SpinBoxSetting_Detection_n  "QSpinBox{font: 14pt ;background:transparent;color:white;border:2px solid " FrameBorderColor_n ";}\
                                          QSpinBox::up-button {subcontrol-origin:border;subcontrol-position:right;margin-right: 2px;width: 36;height: 36;}\
                                          QSpinBox::down-button {subcontrol-origin:border;subcontrol-position:left; margin-left: 2px; width: 36;height: 36;}\
                                          QSpinBox::up-button:pressed{subcontrol-origin:border;subcontrol-position:right;width: 36;height: 36;}\
                                          QSpinBox::down-button:pressed{subcontrol-position:left; width: 36; height: 36;}\
                                          QSpinBox::down-arrow:disabled,QSpinBox::down-arrow:off { width: 36;height: 36;}\
                                          QSpinBox::up-arrow:disabled,QSpinBox::up-arrow:off { width: 36; height: 36;}"

