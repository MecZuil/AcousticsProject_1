#include "hp_dialog_wifi.h"
#include "ui_hp_dialog_wifi.h"

hp_dialog_wifi::hp_dialog_wifi(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_dialog_wifi)
{
    ui->setupUi(this);
    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
    setWindowModality(Qt::WindowModal);

    hp_dateInit();
    hp_winInit();
    hp_connectInit();

    ui->frame->setStyleSheet("background-image: url(:/res/background_1.jpg);");
    ui->frame_STA->setStyleSheet("background:transparent;");
    ui->listWidget_wifiName->setStyleSheet(ListWidgeVerticalSheetStyle_n);
}

hp_dialog_wifi::~hp_dialog_wifi()
{
    delete ui;
}

