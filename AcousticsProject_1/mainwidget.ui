     <property name="styleSheet">
      <string notr="true">QDoubleSpinBox
{
	font: 14pt ;
	background:transparent;
	color:white;
	border:0px solid white;
}

QDoubleSpinBox::Disabled
{
	font: 14pt ;
	background:transparent;
	color:rgb(170, 170, 170);
	border:0px solid rgb(170, 170, 170);
}

QDoubleSpinBox::up-button {
background-image: url(:/res/distanceAdd_n.png);
	subcontrol-origin:border;
    subcontrol-position:right;
	margin-right: 2px;
    width: 50;
    height: 45;       
}
QDoubleSpinBox::down-button {
background-image: url(:/res/distanceReduce_n.png);
	subcontrol-origin:border;
    subcontrol-position:left;
	
   width: 50;
    height: 45; 
}
/*按钮按下样式*/
QDoubleSpinBox::up-button:pressed{
	subcontrol-origin:border;
    subcontrol-position:right;
width: 50;
    height: 45;     
}
  
QDoubleSpinBox::down-button:pressed{
    subcontrol-position:left;
    width: 50;
    height: 45; 
}

QDoubleSpinBox::down-arrow:disabled,QSpinBox::down-arrow:off 
{ 
   width: 50;
    height: 45; 
}

QDoubleSpinBox::up-arrow:disabled,QSpinBox::up-arrow:off 
{ 
   width: 50;
    height: 45; 
}</string>
