//void hp_errorwarning_dialog::setWarningText(QString title ,QString text)
//{
//    ui->textLabel->setText(text);
//    ui->titleLabel->setText(title);
//}
//设置单次响应定时器时间
void hp_errorwarning_dialog::setDelayClose(int ms)
{
    CloseTimer->setInterval(ms);
    CloseTimer->start();
}
//定时器触发事件
void hp_errorwarning_dialog::timer_finish()
{
    close();
}
//确定按钮关闭提示框
void hp_errorwarning_dialog::on_OKToolButton_clicked()
{
    SignalUpdateSetUpClock();
    CloseTimer->stop();
    close();
}
//定时器超时触发事件
void hp_errorwarning_dialog::SlotCloseTimer()
{
    CloseTimer->stop();
    close();
}
