     <property name="focusPolicy">
      <enum>Qt::StrongFocus</enum>
     </property>
     <property name="styleSheet">
      <string notr="true">QDoubleSpinBox
{
	font: 17pt &quot;微软雅黑&quot;;
	background:transparent;
	color:white;
	border:1px solid rgba(199, 199, 199, 150);
}
QDoubleSpinBox::up-button {
	subcontrol-origin:border;
    subcontrol-position:right;
	margin-right: 2px;
    width: 36;
    height: 36;       
}
QDoubleSpinBox::down-button {
	subcontrol-origin:border;
    subcontrol-position:left;
	margin-left: 2px;
    width: 36;
    height: 36;
}
/*按钮按下样式*/
QDoubleSpinBox::up-button:pressed{
	subcontrol-origin:border;
    subcontrol-position:right;
    width: 36;
    height: 36;       
}
  
QDoubleSpinBox::down-button:pressed{
    subcontrol-position:left;
    width: 36;
    height: 36;
}

QDoubleSpinBox::down-arrow:disabled,QSpinBox::down-arrow:off 
{ 
    width: 36;
    height: 36;
}

QDoubleSpinBox::up-arrow:disabled,QSpinBox::up-arrow:off 
{ 
    width: 36;
    height: 36;
}</string>
     </property>
