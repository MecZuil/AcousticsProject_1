bool hp_dialog_ircolor::set_sebiao(int sb)
{
    sebiao = sb;
//    signal_update_lcdoff_time(false);
    switch(sebiao)
    {
    case 1:
        ui->toolButton_1->setChecked(true);
        break;
    case 2:
        ui->toolButton_2->setChecked(true);
        break;
    case 10:
        ui->toolButton_10->setChecked(true);
        break;
    case 11:
        ui->toolButton_11->setChecked(true);
        break;
    case 12:
        ui->toolButton_12->setChecked(true);
        break;
    case 13:
        ui->toolButton_13->setChecked(true);
        break;
    case 14:
        ui->toolButton_14->setChecked(true);
        break;
    case 15:
        ui->toolButton_15->setChecked(true);
        break;
    case 16:
        ui->toolButton_16->setChecked(true);
        break;
    case 17:
        ui->toolButton_17->setChecked(true);
        break;
    case 18:
        ui->toolButton_18->setChecked(true);
        break;
    case 19:
        ui->toolButton_19->setChecked(true);
        break;
    case 20:
        ui->toolButton_20->setChecked(true);
        break;
    case 21:
        ui->toolButton_21->setChecked(true);
        break;
    case 22:
        ui->toolButton_22->setChecked(true);
        break;
    default:
        break;
    }

    return true;
}

int hp_dialog_ircolor::get_sebiao()
{
    return sebiao;
}

//信号反馈 - 设置红外伪彩
void hp_dialog_ircolor::slot_pc_key_set_ir_color(unsigned char return_value,int data)
{
    qDebug("hp_dialog_ircolor::slot_pc_key_set_ir_color(unsigned char return_value : 0x%02x , data : %d",return_value,data);
//    if(data == 1)
//    {
        Sleep(100);
        setButtonGroupEnabled(true);
        LoadWhirlProgressBarDialog->StopLoadTimer();
//    }
}

//色标按钮组点击事件
void hp_dialog_ircolor::sebiaoButtonGroupChecked(QAbstractButton* bt,bool checked)
{
    setButtonGroupEnabled(false);
    if(bt->objectName() == "toolButton_1")
    {
        if(checked)
        {
            LoadWhirlProgressBarDialog->StartLoadTimer(ui->toolButton_1->x(),ui->toolButton_1->y(),ui->toolButton_1->width(),ui->toolButton_1->height());
            signal_pc_key_set_ir_color(1);
            sebiao = 1;
        }
    }
    if(bt->objectName() == "toolButton_2")
    {
        if(checked)
        {
            LoadWhirlProgressBarDialog->StartLoadTimer(ui->toolButton_2->x(),ui->toolButton_2->y(),ui->toolButton_2->width(),ui->toolButton_2->height());
            signal_pc_key_set_ir_color(2);
            sebiao = 2;
        }
    }
    if(bt->objectName() == "toolButton_10")
    {
