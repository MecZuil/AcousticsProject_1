void hp_dialog_ircolor::setButtonGroupEnabled(bool isEnabled)
{
    ui->frame_gray->setVisible(!isEnabled);
    ui->toolButton_1->setEnabled(isEnabled);
    ui->toolButton_2->setEnabled(isEnabled);
    ui->toolButton_10->setEnabled(isEnabled);
    ui->toolButton_11->setEnabled(isEnabled);
    ui->toolButton_12->setEnabled(isEnabled);
    ui->toolButton_13->setEnabled(isEnabled);
    ui->toolButton_14->setEnabled(isEnabled);
    ui->toolButton_15->setEnabled(isEnabled);
    ui->toolButton_16->setEnabled(isEnabled);
    ui->toolButton_17->setEnabled(isEnabled);
    ui->toolButton_18->setEnabled(isEnabled);
    ui->toolButton_19->setEnabled(isEnabled);
    ui->toolButton_20->setEnabled(isEnabled);
    ui->toolButton_21->setEnabled(isEnabled);
    ui->toolButton_22->setEnabled(isEnabled);
}
