#include "hp_dialog_ircolor.h"
#include "ui_hp_dialog_ircolor.h"

hp_dialog_ircolor::hp_dialog_ircolor(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_dialog_ircolor)
{
    ui->setupUi(this);

    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
//    setWindowModality(Qt::WindowModal);

    setGeometry(70,480-this->height(),width(),height());
    setFixedSize(this->width(), this->height());
    ui->toolButton_1->setChecked(true);
//    ui->gridFrame->setStyleSheet("QFrame{background-color:rgb(13, 34, 67);border :none;}");
    connect(ui->buttonGroup,SIGNAL(buttonToggled(QAbstractButton*,bool)),this,SLOT(sebiaoButtonGroupChecked(QAbstractButton*,bool)));

    LoadWhirlProgressBarDialog = new hp_load_whirl(this);
    LoadWhirlProgressBarDialog->close();
    ui->frame_gray->setVisible(false);
}

hp_dialog_ircolor::~hp_dialog_ircolor()
{
    delete ui;
}

