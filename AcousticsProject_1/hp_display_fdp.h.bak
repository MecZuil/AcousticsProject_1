    int dataCount;
    int y_topLine;
    int y_buttonLine;
    int tickOffset;//刻度值偏移量
    int cyRatio;//实际刻度与y轴的比例

    bool is10KSetEnabled;//是否开放10K以下设置 0-10K以下均当做10K发送 1-10K以下正常发送
    bool chooseTopLine;
    bool chooseBottomLine;
    bool chooseMoveRect;

    double_range SendDoubleRange;
    double f;
//    QCPMarginGroup *marginGroup;
    QCPItemText *currentPoint_y;

    QPoint press_point;
    QPoint current_point;
