    bool isSLMOpen;//SLM智能场景是否打开
    bool isAdaptiveOpen;//频域选择自适应是否打开

protected:
    virtual void mousePressEvent(QMouseEvent *ev);
//    virtual void paintEvent(QPaintEvent *ev) override;
    virtual void mouseMoveEvent(QMouseEvent *ev);
    virtual void mouseReleaseEvent(QMouseEvent *ev);

signals:
    void signal_pc_fpga_set_freq_start(int data);
    void signal_pc_sys_set_freq_anser();
    void signal_pc_key_set_freq_range(double_range doubleRange);

    void SignalUpdateSetUpClock();

