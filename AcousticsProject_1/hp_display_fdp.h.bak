    void slot_pc_key_get_freq_range(unsigned char return_value,double_range range);


private slots:
    void slot_pc_fpga_set_freq_start(unsigned char return_value);
    void slot_pc_stream_data(unsigned char return_value,unsigned char * data);
    void slot_pc_sys_set_freq_anser(unsigned char return_value);
    void slot_pc_key_set_freq_range(unsigned char return_value);


