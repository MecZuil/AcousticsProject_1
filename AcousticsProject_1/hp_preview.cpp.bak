                ui->toolButton_edit->setStyleSheet( "QToolButton{border-image: url(" UI_res_PATH_1920 "edit_s.png);}\
                                                    QToolButton::pressed{border-image: url(" UI_res_PATH_1920 "edit_s.png);}\
                                                    QToolButton::disabled{border-image: url(" UI_res_PATH_1920 "edit_d.png);}");
