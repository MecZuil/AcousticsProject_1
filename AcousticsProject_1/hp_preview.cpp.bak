//变量初始化
void hp_preview::hp_dataInit()
{
    isPD = false;
    isGas = false;
    isLongKey = false;
    isNormal = false;
    isUnkown = false;
    isCollect = false;
    isSdInsert = false;
    isVoicePlay = false;
    isVideoPlay = false;
    isSDPathExist = false;
    isSDUpdateSuccess = true;
    isVideoProcessStart = false;
    isAnimationUp = false;
    isAudioPress = false;
    isBluConnected = false;
    isShowMoreInfo = true;
    isLoadingListWidget = false;
    isLoadingItem = false;
    isClosePreview = false;
    isVideoHaveAudio = false;
    isClientConnected = false;


    UIType = 0;
    PicNum=0;
    AviNum=0;
    loadingNum = 1;
    ThumbnailNum=0;
    sd_info.usedMB=0;
    sd_info.totalMB=0;
    AviPlayFirstCount = 0;

    currentSelect = PREVIEW_ListWidget;

    ResourcesListDirect = "/home/root/res/ResourcesList";
    FileDirect = "/run/media/mmcblk2p1/DCIM";

    SlotSDInsert();

    hp_updateStatus(true);

}
//界面初始化
void hp_preview::hp_winInit()
{

    ui->frame->setStyleSheet("background:black; border :none;");
    ui->frame_pic->setStyleSheet("background:black; border :none;");
    ui->frame_vid->setStyleSheet("background:black; border :none;");
    ui->frame_button->setStyleSheet("background:black; border :none;");
    maskImage = new QImage(":/res/mask.png");
    (*maskImage) = maskImage->scaled(320,240);
    VideoPlayerProcess = new QProcess(this);
    FormatDialog = new hp_formatdialog(this);
    FormatDialog->close();
    ErrorWarningDialog = new hp_errorwarning_dialog(this);
    ErrorWarningDialog->close();
    HpInputText = new hp_input_text(this);
    HpInputText->hp_setIns(INPUT_PREVIEW);
    HpInputText->close();

    m_pipeLineMsgTimer = new QTimer(this);
    connect(m_pipeLineMsgTimer, SIGNAL(timeout()), this, SLOT(query_position_and_duration()));


    //    HpStatusBoxTop = new hp_statusbox_top(this);
    //    HpStatusBoxTop->move(800-200,0);
    hp_setListWidgetStyle();//设置表格样式
    ui->frame_pic->close();
    ui->frame_vid->close();
    ui->pictureShow->close();
    ui->label_videoPlayTime->close();
    ui->label_PicUpload->close();
    ui->toolButton_PicUpload->close();

    ui->slider_video_2->close();

    hp_setToolButtonEnabled(false,false,true);
    ui->edit_name->setPlainText("");//初始化右侧信息栏

    ui->frame_pic->setGeometry(800,119,200,241);
    ui->frame_pic->close();
    ui->frame_vid->setGeometry(800,119,200,241);
    ui->frame_vid->close();
    ui->frame_button->setGeometry(800,360,201,40);

    if(isShowMoreInfo)
    {
        QScroller *scroller=QScroller::scroller(ui->scrollArea_picInfo);
        scroller->grabGesture(ui->scrollArea_picInfo,QScroller::LeftMouseButtonGesture);//鼠标左键移动滑动条

        ui->scrollAreaWidgetContents_picInfo->setGeometry(0,0,195,400);

        //设置滑动条是否显示
        //        ui->scrollArea_picInfo->setHorizontalScrollBarPolicy(Qt::ScrollBarAlwaysOff);
        //        ui->scrollArea_picInfo->setVerticalScrollBarPolicy(Qt::ScrollBarAlwaysOff);
    }
    else
    {
        ui->label_PFPower->close();
        ui->edit_PFPower->close();
        ui->label_range->close();
        ui->edit_range->close();
        ui->label_threshold->close();
        ui->edit_threshold->close();
        ui->label_freqL->close();
        ui->edit_freqL->close();
        ui->label_freqH->close();
        ui->edit_freqH->close();
        ui->scrollAreaWidgetContents_picInfo->setGeometry(0,0,195,250);
    }

    ui->listWidget->installEventFilter(this);
    ui->toolButton_edit->installEventFilter(this);
    ui->toolButton_close->installEventFilter(this);
    ui->toolButton_delete->installEventFilter(this);
    ui->toolButton_voiceNotes->installEventFilter(this);
    ui->listWidget->viewport()->installEventFilter(this);
    ui->pictureShow->installEventFilter(this);
    ui->label_page->installEventFilter(this);



    hp_InitAnimation();
}
