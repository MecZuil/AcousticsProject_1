//SD卡格式化后
void hp_preview::slot_pc_sys_formatting_sd(unsigned char return_value)
{
    qDebug("##--------------------------hp_preview::slot_pc_sys_formatting_sd:return_value:0x%02x",return_value);
    if(return_value==RE_OK)
    {
        ThumbnailNum=0;
        PicNum=0;
        AviNum=0;
        listIndex=0;
        loadingNum = 1;
        FileList.clear();
        FileNameList.clear();
        ui->listWidget->clear();
        FileNameList.clear();
        ui->label_allPage->setText("1");
        ui->label_page->setText(QString::number(loadingNum));
        hp_updateCurrentItemInfo(false);
        hp_setToolButtonEnabled(false,false,true);
    }
}
//SD卡插入时的操作
void hp_preview::SlotSDInsert()
{
    //    isLoadingListWidget = true;
    QString str;
    listIndex = 0;
    //    system("rm -rf /home/root/res/TempStoragePng/*");//先清空设备内存储文件
    hp_setToolButtonEnabled(false,false,true);
    isSDUpdateSuccess=hp_updateDir();
    qDebug()<<"isSDUpdateSuccess = "<<isSDUpdateSuccess;
    if(isSDUpdateSuccess)
    {
        ShowCurrentPage();
    }
    else
    {
        //清空当前列表,显示加载错误
    }

    ui->listWidget->setEnabled(true);
    //    isLoadingListWidget=false;
    //            FormatDialog->close();
}
//SD卡拔出时的操作
void hp_preview::SlotSDPullOut()
{
    QString str;
    MYLOG;
    if(isSDPathExist)
    {
        str =tr("SD卡错误");
    }
    else
    {
        str=tr("SD卡未插入");
    }
    ui->edit_SD->setText(str);
    ThumbnailNum =0;
    PicNum=0;
    AviNum=0;
    loadingNum = 1;
    listIndex=0;
    FileList.clear();
    ui->listWidget->clear();
    FileNameList.clear();
    ui->label_allPage->setText("1");
    ui->label_page->setText(QString::number(loadingNum));
    hp_setToolButtonEnabled(false,false,true);
    hp_updateCurrentItemInfo(false);

}
//SD卡容量信息更新
void hp_preview::hp_setEditSD(QString sdInfo)
{
    ui->edit_SD->setText(sdInfo);
}
//更新SD卡的内容
bool hp_preview::hp_updateDir()
{
    QDir dir("/run/media/mmcblk2p1/DCIM");
    QStringList filters;
    //    bool isExit=false;
    FileList.clear();
    FileNameList.clear();
    filters.clear();
    filters.append(QString("*.jpg"));
    filters.append(QString("*.avi"));
    //设置进入的目录显示的筛选条件
    dir.setFilter(QDir::Files | QDir::Hidden | QDir::NoSymLinks);//只列出文件 列出隐藏文件 不列出符号连接
    dir.setNameFilters(filters);
    dir.setSorting(QDir::Name | QDir::Reversed);//按名字的反序

    QFileInfoList fileList;//未按后缀排序的

    fileList=dir.entryInfoList();

    loadingNum = 1;
    ThumbnailNum = 0;
    PicNum = 0;
    AviNum = 0;
//    qDebug()<<"filelist size : "<<fileList.size();

    for(int i=0; i<fileList.size(); i++)
    {
        QFileInfo fileInfo = fileList.at(i);
//        qDebug()<<"fileInfo.fileName = "<<fileInfo.fileName();
        if( fileInfo.fileName().contains(".avi",Qt::CaseInsensitive))
        {
            if(fileInfo.fileName().contains("VID",Qt::CaseInsensitive))
            {
                FileList.append(fileList.at(i));
                AviNum++;
                ThumbnailNum++;
            }
        }
    }
    for(int i = 0;i<fileList.size();i++)
    {
        QFileInfo fileInfo = fileList.at(i);
        if( fileInfo.fileName().contains(".jpg",Qt::CaseInsensitive))
        {
            FileList.append(fileList.at(i));
            FileNameList.append(fileInfo.fileName());
            PicNum++;
            ThumbnailNum++;
        }
    }
    QString str;
    //    if(ThumbnailNum != 0)
    if(ThumbnailNum % 4 ==0)
    {
        if(ThumbnailNum == 0)
            MaxPageCount = 1;
        else
            MaxPageCount = ThumbnailNum/4;
    }
    else
        MaxPageCount = ThumbnailNum/4+1;

    str = QString::number(MaxPageCount);

    ui->label_allPage->setText(str);
    ui->label_page->setText(QString::number(loadingNum));

    for(int i = 0;i<FileList.size();i++)
    {
        MYLOG<<"****"<<FileList.at(i).fileName();
    }

    UpdateResourcesListFile();

    return true;
}
//更新视频图片资源列表文件
void hp_preview::UpdateResourcesListFile()
{
    FILE *fresourcesList = fopen(ResourcesListDirect,"w+");//打开可读写文件 每次打开内容都将清空

    for(int i=0; i<FileList.size(); i++)
    {
        QFileInfo fileInfo = FileList.at(i);
        if( fileInfo.fileName().contains(".avi",Qt::CaseInsensitive) )   //CaseInsensitive 比较字符串不区分大小写
        {
            if(fileInfo.fileName().contains("VID",Qt::CaseInsensitive))
            {
                QByteArray bfileName = fileInfo.fileName().toLatin1();
                //                char *lineFeedSymbol ="\n";
                char *cfileName = bfileName.data();//转化为纯字符数组
                fwrite(cfileName,fileInfo.fileName().length(),1,fresourcesList);
                fwrite("\n",1,1,fresourcesList);
                //                printf("%s\n",cfileName);
            }
        }
        else if( fileInfo.fileName().contains(".jpg",Qt::CaseInsensitive) )
        {
            QByteArray bfileName = fileInfo.fileName().toLatin1();
            //                char *lineFeedSymbol ="\n";
            char *cfileName = bfileName.data();//转化为纯字符数组
            fwrite(cfileName,fileInfo.fileName().length(),1,fresourcesList);
            fwrite("\n",1,1,fresourcesList);
            //                printf("%s\n",cfileName);
        }
    }
    fclose(fresourcesList);
    return;
}

//检查开发板上是否有TempStoragePng这个文件夹
void hp_preview::StartCheckFile()
{
    QDir dir;
    QString Strdirect="./res/TempStoragePng";
    QFileInfo fileInfo(Strdirect);

    if( !fileInfo.isDir() )//判断是否存在文件夹
        dir.mkdir(Strdirect);//不存在 创建文件夹
    else
        DeleVideoForJPG();//开机清空文件夹下的图片
}
//删除提取到的视频的第一帧图片
void hp_preview::DeleVideoForJPG()
{
    QString cmd;
    QByteArray  SysCommand;

    cmd = "rm /home/root/res/TempStoragePng/VID*";

    SysCommand=cmd.toLatin1();
    system(SysCommand);
    return ;
}
//获取视频第一帧图片
int hp_preview::VideoForJPG(QString file,QString filename)
{
    QString cmd;
    QProcess process;
#if DebugShow
    qDebug()<<"ffmpeg -n -i /run/media/mmcblk2p1/DCIM/"<<file<<" -r 12 -vframes 1 /home/root/res/TempStoragePng/"<<filename<<".jpg";
#endif
    cmd = "ffmpeg -n -i /run/media/mmcblk2p1/DCIM/"+file+" -r 12 -vframes 1 /home/root/res/TempStoragePng/"+filename+".jpg";
    //通过过execute函数是阻塞 直到我们启动的外部程序结束才会往下进行 如果使用start我发现这个外部程序会被干掉
    process.execute(cmd);
    process.close();
    return 0;
}
//显示SD卡内容
void hp_preview::ShowCurrentPage()
{
    ui->frame_pic->close();
    ui->frame_vid->close();
    ui->pictureShow->close();
    hp_setToolButtonEnabled(false,false,true);
    ui->edit_name->setPlainText("");//初始化右侧信息栏
    ui->listWidget->clear();
    FileNameList.clear();
    SlotShowCurrentPageTimer();
}
//新增列表项 20240926 解决新拍图片未打开预览命名重复时检测不到问题 拍完照临时新增listwidget
void hp_preview::AddListWidgetItem(take_capture_t captureData)
{
    QString fileName = QString::fromUtf8((char *)captureData.filename);
    QString newfileName = QString::fromUtf8((char *)captureData.newfilename);
    bool flag = false;
    QFile fileWrite(ResourcesListDirect);
    QString ret;
    if(fileWrite.open(QIODevice::ReadOnly))
    {
        ret= fileWrite.readAll();
        fileWrite.close();
    }

    QStringList arryListWrite= ret.split("\n");
    //    for(int i=0;i<arryListWrite.size();i++)
    //    {
    //        qDebug()<<arryListWrite.at(i);
    //    }

    if(fileWrite.open(QIODevice::WriteOnly | QIODevice::Text | QIODevice::Truncate))
    {        //文件流写文件
        QTextStream streamWrite(&fileWrite);      //通过文本流控制文件写操作

        for(int i=0;i<arryListWrite.size();i++)
        {      //这里到arryListWrite.size()-1是因为arryListWrite数组按照\n分 段时，最后一行尾部有个\n，所以数组最后一个值为空，需要将它去掉

            if(arryListWrite.at(i).startsWith(fileName))
            {
                flag = true;
                if(captureData.hasNewName)
                {
                    arryListWrite.replace(i,newfileName);
                }
                streamWrite<<arryListWrite.at(i)<<"\n";
            }
            else if(i == arryListWrite.size()-1){
                //                MYLOG<<"i == arryListWrite.size()-1  arryListWrite ["<<i<<"] : "<<arryListWrite.at(i);
                if(captureData.hasNewName)
                    arryListWrite.replace(i,newfileName);
                else
                    arryListWrite.replace(i,fileName);
                //                MYLOG<<"i == arryListWrite.size()-1  arryListWrite ["<<i<<"] : "<<arryListWrite.at(i);
                streamWrite<<arryListWrite.at(i)<<"\n";
            }
            else
            {
                //                MYLOG<<"arryListWrite ["<<i<<"] : "<<arryListWrite.at(i);
                streamWrite<<arryListWrite.at(i)<<"\n";
                //                MYLOG<<"arryListWrite ["<<i<<"] : "<<arryListWrite.at(i);
            }
        }
        for(int i=0;i<arryListWrite.size();i++)
        {
            MYLOG<<"*******"<<arryListWrite[i];
        }
        fileWrite.close();
    }

    //    if(captureData.hasNewName)
    //    {
    //        QString fileName = QString::fromUtf8((char *)captureData.filename);
    //        QString newfileName = QString::fromUtf8((char *)captureData.newfilename);
    //        QList<QListWidgetItem *> matchingItems = ui->listWidget->findItems(fileName, Qt::MatchExactly);
    //        // 获取第一个匹配项对应的 QWidget
    //        if (!matchingItems.isEmpty()) {
    //           ui->listWidget->removeItemWidget(matchingItems[0]);
    //        }
    //        ui->listWidget->addItem(newfileName);
    //        qDebug()<<ui->listWidget->item(ui->listWidget->count()-1);
    //    }
    //    else
    //    {
    //        QString fileName = QString::fromUtf8((char *)captureData.filename);
    //        QList<QListWidgetItem *> matchingItems = ui->listWidget->findItems(fileName, Qt::MatchExactly);
    //        // 获取第一个匹配项对应的 QWidget
    //        if (matchingItems.isEmpty()) {
    //           ui->listWidget->addItem(fileName);
    //           qDebug()<<ui->listWidget->item(ui->listWidget->count()-1);
    //        }
    //    }
}
//分段处理预览界面
void hp_preview::SlotShowCurrentPageTimer()
{
//    qDebug()<<"isSdInsert = "<<isSdInsert;
    if(!isSdInsert)
    {
        return;
    }
    ui->listWidget->clear();
    FileNameList.clear();
    ui->listWidget->setEnabled(false);
    int i;
    int addCount =( loadingNum -1)*4;
//    qDebug()<<"loadingNum : "<<loadingNum;
    for(i=addCount;i<FileList.size() &&addCount<loadingNum * 4;i++)
    {
        QFileInfo fileInfo =FileList.at(i);
        if(fileInfo.fileName().contains(".avi",Qt::CaseInsensitive))
        {
#if DebugShow
            MYLOG<<" addCount avi : "<<addCount<<" fileInfo.fileName() : "<<fileInfo.fileName();
#endif
            QString FileName;
            FileName=fileInfo.fileName().section('.',0,0);
            QFile file(QString("/home/root/res/TempStoragePng/")+FileName+QString(".jpg"));
            //            MYLOG<<file.errorString();
            if(!file.exists())//为了加快切到视频的速度
            {
                qDebug()<<"File jpg is not exists : "<<"/home/root/res/TempStoragePng/"+FileName+".jpg";
                VideoForJPG(fileInfo.fileName(),FileName);
            }
            QImage * VideoFirstImage = new QImage("./res/TempStoragePng/"+FileName+".jpg");
            QPainter painter(VideoFirstImage);
            painter.drawImage(0,0,*VideoFirstImage );
            painter.drawImage(0,0,*maskImage);
            if(! QFile::exists("./res/TempStoragePng/"+FileName+".jpg") )
            {
                qDebug()<<"./res/TempStoragePng/+FileName+.jpg  not exists";
            }
            QIcon icon(QPixmap::fromImage(*VideoFirstImage));
            QListWidgetItem *tmp = new QListWidgetItem(icon, fileInfo.fileName());
            tmp->setSizeHint(QSize(140,100));
            ui->listWidget->addItem(tmp);
            FileNameList.append(fileInfo.fileName());
            addCount++;
        }
    }
//    MYLOG<<addCount;
    //    addCount = ( loadingNum - 1)*4;
    for(i = addCount;i<FileList.size()&&i<loadingNum * 4;i++)
    {
        QFileInfo fileInfo =FileList.at(i);

        if(fileInfo.fileName().contains(".jpg",Qt::CaseInsensitive))
        {
#if DebugShow
            MYLOG<<" addCount jpg: "<<addCount<<" fileInfo.fileName() : "<<fileInfo.fileName();
#endif
            QImage * AddPicThumbnail = new QImage(fileInfo.path()+"/"+fileInfo.fileName());
            QIcon icon(QPixmap::fromImage(*AddPicThumbnail));
            QListWidgetItem *tmp = new QListWidgetItem(icon, fileInfo.fileName());
            tmp->setSizeHint(QSize(140,100));
            ui->listWidget->addItem(tmp);
            update();
#if DebugShow
            qDebug()<<"listwidget count : "<<ui->listWidget->count();
#endif
            FileNameList.append(fileInfo.fileName());
            addCount++;
        }
    }

    ui->listWidget->setEnabled(true);
}
//改变选中缩略图
void hp_preview::on_listWidget_currentRowChanged(int currentRow)
{
    qDebug()<<"hp_preview::on_listWidget_currentRowChanged currentRow : "<<currentRow;
    //clear()会将清空item 也会触发row改变信号 增加空指针判断防止程序崩溃
    if( ui->listWidget->currentItem()== nullptr)
    {
        qDebug()<<"ui->listWidget->currentItem()== nullptr";
        return;
    }
    //获取到图片视频信息之前需要对界面做处理
    isLoadingItem = true;
    hp_updateStatus(false);
    currentSelect = PREVIEW_ListWidget;
    hp_updateStatus(true);
    ui->listWidget->setEnabled(false);
    hp_setToolButtonEnabled(false,false,false);
    hp_updateCurrentItemInfo(false);
    //切换界面需要处理上一个选中的图片视频
    listIndex = currentRow;
    if(isVoicePlay)
    {
        signal_pc_key_set_audio_stopplay();
        isVoicePlay = false;
    }
    if(isVideoProcessStart)
    {
        hp_stopVideoProcess();
    }

    QString SelectFileName;
    SelectFileName=ui->listWidget->currentItem()->text();
    if(isSdInsert&&isSDUpdateSuccess)
    {
        if(SelectFileName.contains(".jpg",Qt::CaseInsensitive))
        {
            ui->edit_name->setPlainText(SelectFileName);
            char *picName = SelectFileName.toUtf8().data();
            printf("send to  core  :%s\n",picName);
            signal_pc_key_get_capture_info(picName);
            //            ui->frame_vid->close();
        }
        else if(SelectFileName.contains(".avi",Qt::CaseInsensitive))
        {
            ui->edit_name->setPlainText(SelectFileName);
            char *aviName = SelectFileName.toUtf8().data();
            printf("send to  core  :%s\n",aviName);
            signal_pc_key_get_avi_streamcount(aviName);
        }
    }
}
//设置当前视频选中信息
void hp_preview::hp_updateCurrentVidItemInfo(int Item)
{
    ui->slider_video->setValue(0);
    ui->label_videoPlayTime->setText(tr("00:00 / 00:00"));
    ui->frame_vid->show();
    ShowVideoFirstPic(0,0,600,360);

}
//获取视频流码流数量返回
void hp_preview::slot_pc_key_get_avi_streamcount(unsigned char return_value,int data)
{
    qDebug("hp_preview::slog_pc_key_get_avi_streamcount(unsigned char reutrn_value : 0x%02x    data : %d",return_value,data);
    if(data == 1)
        isVideoHaveAudio = false;
    else if(data == 2)
        isVideoHaveAudio = true;
    else
        isVideoHaveAudio = true;

    hp_updateCurrentVidItemInfo(listIndex);
    ui->frame_pic->close();
    ui->listWidget->setEnabled(true);
    isLoadingItem = false;
    hp_setToolButtonEnabled(false,true,true);
}
//延时
void hp_preview::Sleep(int msec)
{
    QTime dieTime =QTime::currentTime().addMSecs(msec);
    while (QTime::currentTime()<dieTime)
    {
        QCoreApplication::processEvents(QEventLoop::AllEvents,100);
    }
}
//更新右侧信息栏
void hp_preview::hp_updateCurrentItemInfo(bool isShow)
{
    if(!isShow)
    {
        ui->frame_pic->close();
        ui->frame_vid->close();
        ui->pictureShow->close();

        ui->edit_name->setPlainText("");
    }
    else
    {
        //图片
        QString picture = "/run/media/mmcblk2p1/DCIM/"+ui->listWidget->currentItem()->text();
#if DebugShow
        qDebug()<<"on_listWidget_currentRowChanged : currentPicture : "<<picture;
#endif
        QImage *image=new QImage(picture);
        QPixmap *pixmap = new QPixmap();
        *image=image->scaled(600,360,Qt::IgnoreAspectRatio,Qt::SmoothTransformation);

        pixmap->convertFromImage(*image);
        ui->pictureShow->setPixmap(*pixmap);
        //录音
#if DebugShow
        qDebug()<<"captureData.hasVoice : "<<captureInfo.hasVoice;
#endif
        if(captureInfo.hasVoice)
        {
            ui->toolButton_voiceNotes->show();
        }
        else
        {
            ui->toolButton_voiceNotes->close();
        }
        //备注
        QString Notes = QString::fromUtf8((char *)captureInfo.notes);
        ui->edit_notes->setPlainText(Notes);
        //声源
        if(captureInfo.soundmode == 1)
        {
            ui->edit_ASM->setText(tr("多声源模式"));
        }
        else
        {
            ui->edit_ASM->setText(tr("单声源模式"));
        }
        //动态范围
        QString moveRangeNotes = QString::number(captureInfo.moverange.lower) +'-' + QString::number(1000);
        ui->edit_dynamic_range->setText(moveRangeNotes);

#if DebugShow
        qDebug()<<"captureInfo.notes : "<<Notes<<"\n  captureInfo.soundmode : "<<captureInfo.soundmode<<"\n  captureInfo.moverange : "<<moveRangeNotes;
#endif
        //时间注
        //        QString picTime = ui->listWidget->currentItem()->text().mid(4,8);
        //        picTime.insert(4,'/');
        //        picTime.insert(7,'/');
        struct tm  *ptm = localtime((time_t *)(&captureInfo.tv.tv_sec));//获取当前时间
        //        sprintf(filename, "FPGA_%d%02d%02d_%02d%02d%02d.dat",ptm->tm_year+1900, ptm->tm_mon+1, ptm->tm_mday,
        //                           ptm->tm_hour, ptm->tm_min, ptm->tm_sec);
        QString picTime = QString::number(ptm->tm_year+1900)+'/'+QString::number(ptm->tm_mon+1)+'/'+QString::number(ptm->tm_mday)+'\n'+QString::number(ptm->tm_hour)+':'+QString::number(ptm->tm_min)+':'+QString::number(ptm->tm_sec);

        ui->edit_time->setPlainText(picTime);
        if(isShowMoreInfo)
        {
            //频域
            ui->edit_freqL->setText(QString::number(captureInfo.freqRange.lowwer,'f',2)+" kHz");
            ui->edit_freqH->setText(QString::number(captureInfo.freqRange.upper,'f',2)+" kHz");
            //BF Power(max)
            ui->edit_PFPower->setText(QString::number(captureInfo.bfPowerMax,'f',2)+" dB");
            //阈值DB
            ui->edit_threshold->setText(QString::number(captureInfo.threshold,'f',2)+" dB");
            //范围DB
            ui->edit_range->setText(QString::number(captureInfo.rangedb,'f',2)+" dB");
        }


        ui->frame_pic->show();
        ui->pictureShow->show();
        hp_setToolButtonEnabled(true,true,true);
    }
}
//录音播放按钮点击
void hp_preview::on_toolButton_voiceNotes_clicked()
{
    hp_updateStatus(false);
#if DebugShow
    qDebug()<<"isAudioPress : "<<isAudioPress<<" -----  isBluConnected : "<<isBluConnected;
    qDebug()<<"on_toolButton_voiceNotes_clicked captureInfo.hasVoice:"<<captureInfo.hasVoice;
#endif
    if(isAudioPress || (!isBluConnected))
    {

        isVoicePlay = false;
        hp_updateStatus(true);
        return;
    }

    if(!isVoicePlay)
    {
        hp_setToolButtonEnabled(false,false,true);
        isVoicePlay = true;
        //            hp_updateStatus(true);
        isAudioPress=true;
        signal_pc_key_set_audio_play();
    }
    else
    {
        isVoicePlay = false;
        //            hp_updateStatus(true);
        isAudioPress=true;
        signal_pc_key_set_audio_stopplay();
    }
    currentSelect = PREVIEW_VoiceNote;
    hp_updateStatus(true);
}
//蓝牙开关控制 录音放音
void hp_preview::slot_pc_key_set_ble_inout(unsigned char return_value)
{
    qDebug("hp_preview::slot_pc_key_set_ble_inout(unsigned char return_value : 0x%02x",return_value);
    if(isAudioPress)
        signal_pc_key_set_audio_play();
}
//播放录音反馈
void hp_preview::slot_pc_key_set_audio_play(unsigned char return_value)
{
    qDebug()<<"hp_preview::slot_pc_key_set_audio_play(unsigned char return_value : "<<return_value;
    isAudioPress = false;
}
//停止播放录音反馈
void hp_preview::slot_pc_key_set_audio_stopplay(unsigned char return_value)
{
    qDebug()<<"hp_preview::slot_pc_key_set_audio_stopplay(unsigned char return_value : "<<return_value;
    isVoicePlay = false;
    isAudioPress = false;
    hp_setToolButtonEnabled(true,true,true);
    if(currentSelect == PREVIEW_VoiceNote)
    {
//        qDebug()<<"hp_updateStatus  isSelect : true     PREVIEW_VoiceNote     isVoicePlay : "<<isVoicePlay;
        ui->toolButton_voiceNotes->setStyleSheet("QToolButton{background:transparent;border-image: url(:/res/voicenotes_stop_s.png);}\
                                                 QToolButton::pressed{background:transparent;border-image: url(:/res/voicenotes_stop_s.png);}");
    }
    else
    {
//        qDebug()<<"hp_updateStatus  isSelect : false      PREVIEW_VoiceNote     isVoicePlay : "<<isVoicePlay;
        ui->toolButton_voiceNotes->setStyleSheet("QToolButton{background:transparent;border-image: url(:/res/voicenotes_stop_n.png);}\
                                                 QToolButton::pressed{background:transparent;border-image: url(:/res/voicenotes_stop_n.png);}");

    }

}
//获取选中图像信息并显示
void hp_preview::slot_pc_key_get_capture_info(unsigned char return_value,take_capture_t data)
{
    qDebug("hp_preview::slot_pc_key_get_capture_info(unsigned char return_value : 0x%02x",return_value);
    if(return_value == RE_OK)
    {
        memset(&captureInfo,0,sizeof(take_capture_t));
        memcpy(&captureInfo,&data,sizeof(take_capture_t));
        hp_updateCurrentItemInfo(true);
    }
    else if(return_value == RE_ERR_PARA_RECV)
    {
        char *cPicNotes = ui->listWidget->currentItem()->text().toUtf8().data();
        memset(&captureInfo,0,sizeof(take_capture_t));
        memcpy(&captureInfo.filename,cPicNotes,strlen(cPicNotes));

        //图片
        QString picture = "/run/media/mmcblk2p1/DCIM/"+ui->listWidget->currentItem()->text();
#if DebugShow
        qDebug()<<"on_listWidget_currentRowChanged : currentPicture : "<<picture;
#endif
        QImage *image=new QImage(picture);
        QPixmap *pixmap = new QPixmap();
        *image=image->scaled(600,360,Qt::IgnoreAspectRatio,Qt::SmoothTransformation);
        pixmap->convertFromImage(*image);
        ui->pictureShow->setPixmap(*pixmap);
        hp_setToolButtonEnabled(false,false,true);
        hp_updateCurrentItemInfo(false);
        ui->edit_name->setPlainText(ui->listWidget->currentItem()->text());
        ui->toolButton_delete->setEnabled(true);
        ui->edit_notes->setPlainText("普通格式图片");
        ui->edit_ASM->clear();
        ui->edit_time->clear();
        ui->edit_dynamic_range->clear();
        if(isShowMoreInfo)
        {
            ui->edit_PFPower->clear();
            ui->edit_freqH->clear();
            ui->edit_freqL->clear();
            ui->edit_threshold->clear();
            ui->edit_range->clear();
        }

        ui->frame_pic->show();
        ui->pictureShow->show();

        isLoadingItem = false;
        //        FormatDialog->hp_setDialogType(DIALOG_DELETE);
        //        FormatDialog->hp_setFormatDialogText(tr("图片异常,是否删除?"));
        //        FormatDialog->show();
    }
    ui->listWidget->setEnabled(true);
}
//图像信息编辑后的处理
void hp_preview::slot_pc_key_set_capture_edit(unsigned char return_value)
{
    qDebug()<<"hp_preview::slot_pc_key_set_capture_edit(unsigned char return_value : "<<return_value;
    QString name;
    if(captureInfo.hasNewName)
    {
        int last_count = loadingNum;
        hp_updateDir();
        loadingNum = last_count;
        ui->label_page->setText(QString::number(loadingNum));
        ShowCurrentPage();
//        name = QString::fromLocal8Bit((char *)captureInfo.newfilename);
//        //    qDebug()<<"name : "<<name;
//        ui->listWidget->currentItem()->setText(name);
    }

    on_listWidget_currentRowChanged(listIndex);
}
//文件信息同步
void hp_preview::hp_setCaptureInfo(take_capture_t picInfo)
{
    memset(&captureInfo,0,sizeof(take_capture_t));
    memcpy(&captureInfo,&picInfo,sizeof(take_capture_t));
    captureInfo = picInfo;
}
//查找是否有同名图片 返回false代表有同名文件 true代表无同名文件
bool hp_preview::hp_ChangePicInfo(take_capture_t picInfo)
{
//    memset(&captureInfo,0,sizeof(take_capture_t));
//    memcpy(&captureInfo,&picInfo,sizeof(take_capture_t));
//    captureInfo = picInfo;
    QString picInfoPath ;

    if(captureInfo.hasNewName)
    {
        if(ui->listWidget->count() != 0)//图片列表有图片
        {
            QString name_old = QString::fromLocal8Bit((char *)captureInfo.filename);
            QString name_new = QString::fromLocal8Bit((char *)captureInfo.newfilename);

            QString ResourcesListFileName;
            QFile ResourcesListFile(ResourcesListDirect);
            if(ResourcesListFile.open(QIODevice::ReadOnly))
            {
                ResourcesListFileName = ResourcesListFile.readAll();
                ResourcesListFile.close();
            }
//            MYLOG<<ResourcesListFileName<<" name_new : "<<name_new;
            if(!ResourcesListFileName.contains(name_new))
            {
                return true;
            }
            else
            {
                QStringList strs = ResourcesListFileName.split("\n");
                if(strs.count() == 0)
                    return true;
                for(QString str : strs)
                {
//                    MYLOG<<"str : "<<str <<" name_new : "<<name_new;
                    if(str == name_new)
                    {
                        return false;
                    }
                }
                return true;
            }
        }
    }
}

//上一页按钮响应
void hp_preview::on_toolButton_LastPage_clicked()
{
    hp_updateStatus(false);
    currentSelect = PREVIEW_LastPage;
    hp_updateStatus(true);

    if(loadingNum>1)
    {
        loadingNum--;

        ui->label_page->setText(QString::number(loadingNum));
        ui->listWidget->setEnabled(false);
        hp_setToolButtonEnabled(false,false,false);
        hp_updateCurrentItemInfo(false);

        ShowCurrentPage();

        hp_setToolButtonEnabled(false,false,true);
    }

}
//下一页按钮响应
void hp_preview::on_toolButton_NextPage_clicked()
{
    hp_updateStatus(false);
    currentSelect = PREVIEW_NextPage;
    hp_updateStatus(true);
    if(loadingNum * 4 < FileList.size())
    {
        loadingNum ++ ;
        ui->label_page->setText(QString::number(loadingNum));
        ui->listWidget->setEnabled(false);
        hp_setToolButtonEnabled(false,false,false);
        hp_updateCurrentItemInfo(false);

        ShowCurrentPage();

        hp_setToolButtonEnabled(false,false,true);
    }
}
void hp_preview::hp_slot_text_over(QString text,INPUT_NOW_SHOW nowShow)
{
    if(nowShow == INPUT_PREVIEW)
    {

        int page = Limit(text.toInt(),MaxPageCount,1);
        if(loadingNum == page)
            return;
        else
        {
            loadingNum = page;

            ui->label_page->setText(QString::number(loadingNum));
            hp_setToolButtonEnabled(false,false,false);
            hp_updateCurrentItemInfo(false);
            ShowCurrentPage();
            hp_setToolButtonEnabled(false,false,true);
        }

    }
}
//停止视频
void hp_preview::hp_videoStop()
{
    VideoPlayerProcess->kill();
}
//视频开始播放
void hp_preview::VideoPlayerReadData()
{

//    qDebug()<<"VideoPlayerReadData";
    while(!VideoPlayerProcess->atEnd())
    {
        QString s = QLatin1String(VideoPlayerProcess->readLine());
        qDebug()<<"ReadData == "<< s;
        if(!isSdInsert)
        {
            isVideoPlay = false;
            isVideoProcessStart = false;
            VideoPlayerProcess->close();
            ui->slider_video->setValue(0);
            ui->label_videoPlayTime->setText(tr("00:00 / 00:00"));
            ui->toolButton_videoPlay->setText(tr("播放"));
            hp_stopVideoProcess();
        }
        if(s.contains("gplay meet internal error: Could not demultiplex stream"))
        {
            isVideoPlay = false;
            isVideoProcessStart = false;
            VideoPlayerProcess->close();
            ui->slider_video->setValue(0);
            ui->label_videoPlayTime->setText(tr("00:00 / 00:00"));
            ui->toolButton_videoPlay->setText(tr("播放"));
            hp_stopVideoProcess();
            FormatDialog->hp_setDialogType(DIALOG_OKCANCEL);
            FormatDialog->hp_setFormatDialogText(tr("视频播放错误,是否删除该视频?"));
            FormatDialog->show();
            return;
        }
        if(s.contains("[00:00:00",Qt::CaseInsensitive))
        {

        }
        //进度条处理
        if(s.contains("(No Repeated)",Qt::CaseInsensitive))
        {
            int idx = s.indexOf("/");
            QString nowTime = s.mid(idx - 8,8);
            QString endTime = s.mid(idx + 1,8);

            int value_h_max = s.mid(idx+1,2).toInt();
            int value_m_max = s.mid(idx+4,2).toInt();
            int value_s_max = s.mid(idx+7,2).toInt();
            ui->slider_video->setMaximum(value_h_max*3600+value_m_max*60+value_s_max);

            int value_h = s.mid(idx-8,2).toInt();
            int value_m = s.mid(idx-5,2).toInt();
            int value_s = s.mid(idx-2,2).toInt();
            ui->slider_video->setValue(value_h*3600+value_m*60+value_s);

            QString videoPlayTimeStr = QString::number(value_m_max)+":"+QString::number(value_s_max)+" / "+QString::number(value_m)+":"+QString::number(value_s);

            //            if(videoPlayTimeStr == ui->label_videoPlayTime->text())
            //            {

            //                AviPlayFirstCount = 1;
            //                //                QString videoPath = "/run/media/mmcblk2p1/DCIM/"+ui->listWidget->currentItem()->text();
            //                //                qDebug()<<"video : "<<videoPath<<"will play!!!!!!!!!";
            //                //                QString cmd = "gplay-1.0 " + videoPath + " --video-sink=\"overlaysink display-master=true display-slave=true\"";
            //                //                qDebug()<<cmd;
            //                //                VideoPlayerProcess->start(cmd);
            //                //        ShowVideoFirstPic(0,0,600,480);
            //                qDebug() << __func__;
            //                QString SameScreenCmd;
            //                std::string strSameScrValue = " ! decodebin ! videoscale ! video/x=640,height=480 ! tee name=t ! queue ! videoconvert ! fbdevsink device=/dev/fb0 t. ! queue ! videoconvert ! fbdevsink device=/dev/fb2";
            //                QByteArray stdSameScrByte = QByteArray::fromStdString(strSameScrValue);
            //                QString SameScreenCmdPara = stdSameScrByte;
            //                SameScreenCmd = "filesrc location=/run/media/mmcblk2p1/DCIM/" + ui->listWidget->currentItem()->text() + SameScreenCmdPara;

            //                qDebug()<<"video file audio :"<<getAudioSize(ui->listWidget->currentItem()->text());

            //                qDebug() << __func__ << "cmd order = " << SameScreenCmd;

            //                pipeline = gst_parse_launch(SameScreenCmd.toLocal8Bit().data(), NULL);
            //                if (!pipeline) {
            //                    qDebug() << "Failed to create pipeline";
            //                }
            //                else
            //                {
            //                    // 获取管道总线
            //                    m_pipeLineMsgTimer->start(1000);
            //                    bus = gst_element_get_bus(pipeline);
            //                }

            //                VideoPlayerProcess->kill();

            //                gst_element_set_state(pipeline, GST_STATE_PLAYING);//设置为播放状态GST_STATE_PLAYING， 暂停为GST_STATE_PAUSED,从暂停恢复播放只需要重新设置为PLAYING即可
            //                return ;
            //            }


            ui->label_videoPlayTime->setText(videoPlayTimeStr);

        }
        //视频播放结束
        if(s.indexOf("Exit display thread")!=-1)
        {
            hp_stopVideoProcess();
        }
    }
}
//结束播放按钮 [x]eXit
void hp_preview::on_toolButton_videoStop_clicked()
{
    hp_updateStatus(false);
    currentSelect = PREVIEW_VideoStop;
    hp_updateStatus(true);
    if(isVideoProcessStart)
    {
        hp_stopVideoProcess();
    }
}
