//视频播放结束
void hp_preview::hp_stopVideoProcess()
{
    //    VideoPlayerProcess->kill();
    if(AviPlayFirstCount==1)
    {
        gst_element_set_state(pipeline, GST_STATE_NULL);
        gst_object_unref(GST_OBJECT(pipeline));
        m_pipeLineMsgTimer->stop();
        qDebug() << __func__;
        //结束播放释放管道
    }
    else
    {
        VideoPlayerProcess->kill();
    }

    AviPlayFirstCount = 0;

    ui->toolButton_delete->setEnabled(true);
    ui->slider_video->setValue(0);
    ui->slider_video_2->setValue(0);
    ui->label_videoPlayTime->setText(tr("00:00 / 00:00"));
    ui->toolButton_videoPlay->setText(tr("播放"));
    isAnimationUp = true;
    hp_AnimationUp();
    VideoAnimationGroup->start();
    isVideoProcessStart = false;
    isVideoPlay = false;
}
//动画初始化
void hp_preview::hp_InitAnimation()
{
    FrameAnimation = new QPropertyAnimation(this);
    FrameAnimation->setDuration(500);
    FrameAnimation->setTargetObject(ui->frame);

    ListWidgetAnimation = new QPropertyAnimation(this);
    connect(FrameAnimation,&QPropertyAnimation::finished, this, &hp_preview::SlotListWidgetAnimation);
    ListWidgetAnimation->setTargetObject(this);
    ListWidgetAnimation->setDuration(500);
    ListWidgetAnimation->setTargetObject(ui->listWidget);

    VideoAnimationGroup = new QParallelAnimationGroup(this);
    VideoAnimationGroup->setLoopCount(1);
}
//向下滑出动画
void hp_preview::hp_AnimationDown()
{
    ListWidgetAnimation->setPropertyName("pos");
    ListWidgetAnimation->setStartValue(QPoint(ui->listWidget->x(),ui->listWidget->y()));
    ListWidgetAnimation->setEndValue(QPoint(0,500));

    FrameAnimation->setPropertyName("pos");
    FrameAnimation->setStartValue(QPoint(ui->frame->x(),ui->frame->y()));
    FrameAnimation->setEndValue(QPoint(0,0));

    VideoAnimationGroup->addAnimation(ListWidgetAnimation);
    VideoAnimationGroup->addAnimation(FrameAnimation);
}
//向上出现动画
void hp_preview::hp_AnimationUp()
{
    ListWidgetAnimation->setPropertyName("pos");
    ListWidgetAnimation->setStartValue(QPoint(ui->listWidget->x(),ui->listWidget->y()));
    ListWidgetAnimation->setEndValue(QPoint(0,360));

    FrameAnimation->setPropertyName("pos");
    FrameAnimation->setStartValue(QPoint(ui->frame->x(),ui->frame->y()));
    FrameAnimation->setEndValue(QPoint(-200,0));

    VideoAnimationGroup->addAnimation(ListWidgetAnimation);
    VideoAnimationGroup->addAnimation(FrameAnimation);
}
