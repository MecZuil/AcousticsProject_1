void hp_preview::changeEvent(QEvent *e)
{
    QWidget::changeEvent(e);
    switch(e->type())
    {
    case QEvent::LanguageChange:
        ui->retranslateUi(this);
        break;
    default:
        break;
    }
}

bool hp_preview::eventFilter(QObject *o,QEvent *e)
{
    if(e->type()==QEvent::MouseButtonPress)
    {
#if DebugShow
        qDebug("hp_preview::eventFilter e->type()=QEvent::MouseButtonPress");
#endif
        SignalUpdateSetUpClock();
    }

    if(e->type() == QEvent::MouseButtonRelease)
    {
#if DebugShow
        qDebug("hp_preview::eventFilter e->type()=QEvent::MouseButtonRelease");
#endif
        if(o->objectName() == "label_page")
        {
            hp_updateStatus(false);
            currentSelect = PREVIEW_NowPage;
            hp_updateStatus(true);
            if(HpInputText->isHidden())
            {
                HpInputText->hp_setText(ui->label_page->text());
                HpInputText->hp_setShow(INPUT_SHOW_NUM);
                HpInputText->show();
                HpInputText->raise();
            }
        }
    }
    return false;
}

void hp_preview::keyPressEvent(QKeyEvent *ev)
{
    if(!(isLongKey=ev->isAutoRepeat()))
    {
#if DebugShow
        qDebug()<<" hp_preview::keyReleaseEvent(QKeyEvent *ev)---------- ev->key() = "<<ev->key();
#endif
        SignalUpdateSetUpClock();
    }
}

void hp_preview::keyReleaseEvent(QKeyEvent *ev)
{
#if DebugShow
    qDebug()<<" hp_preview::keyReleaseEvent(QKeyEvent *ev)---------- ev->key() = "<<ev->key();
#endif
    SignalUpdateSetUpClock();
    if(isLoadingListWidget)
        return;
    QPixmap map;
    switch (ev->key()) {
    case Key_RETURN:
        KeyReturnHandle();
        break;
    case Key_CAPTURNANDVIDEO:
        SignalPrintscreenHandle();
        //        map = this->grab();
        //        map.save("/run/media/mmcblk2p1/DCIM/preview1.png");
        //        map = QPixmap::grabWindow(this->winId());
        //        map.save("/run/media/mmcblk2p1/DCIM/preview2.jpg");
        //        signal_pc_key_get_grab();
        //        system("sync");
        break;
        //    case Qt::Key_O:
        //        signal_pc_key_get_grab();
        break;
    default:
        break;
    }
}

void hp_preview::mousePressEvent(QMouseEvent *event)
{
    qDebug("void hp_preview::mousePressEvent(QMouseEvent *event)");
    SignalUpdateSetUpClock();
}
//设置列表样式
void hp_preview::hp_setListWidgetStyle()
{
    ui->listWidget->setIconSize(QSize(100,75));                 //设置QListWidget中的单元项的图片大小
    ui->listWidget->setSpacing(2);                             //设置单元格间距
    ui->listWidget->setFlow(QListView::LeftToRight);          //设置单元格从左到右排序
    ui->listWidget->setWrapping(false);                      //防止自动换行
    //    ui->listWidget->setResizeMode(QListView::Adjust);       //设置单元项自适应
    //    ui->listWidget->setViewMode(QListView::IconMode);//设置单元格类型
    ui->listWidget->setVerticalScrollBarPolicy(Qt::ScrollBarAlwaysOff);
    ui->listWidget->setHorizontalScrollBarPolicy(Qt::ScrollBarAlwaysOn);     //设置滑动条是否显示
    QScroller *scroller=QScroller::scroller(ui->listWidget);
    scroller->grabGesture(ui->listWidget,QScroller::LeftMouseButtonGesture);//鼠标左键移动滑动条
    ui->listWidget->setMovement(QListView::Static);//使列表项不可被拖动位置
}
//编辑
void hp_preview::on_toolButton_edit_clicked()
{
    hp_updateStatus(false);
    currentSelect = PREVIEW_Edit;
    hp_updateStatus(true);
    hp_updateCurrentItemInfo(false);
    //    if(!ui->listWidget->currentItem())
    //        return;
    signal_hp_capture_save_open(PREVIEW_PIC_SAVE,captureInfo);
}
//返回
void hp_preview::on_toolButton_close_clicked()
{
    if(isClosePreview)
        return;
    isClosePreview = true;
    hp_updateStatus(false);
    currentSelect = PREVIEW_Return;
    hp_updateStatus(true);

    hp_setToolButtonEnabled(false,false,false);
    if(isVoicePlay)
    {
        signal_pc_key_set_audio_stopplay();
        Sleep(10);
        isVoicePlay = false;
    }
    if(isVideoProcessStart)
    {
        hp_stopVideoProcess();
        Sleep(200);
    }
    isLoadingListWidget = true;
    hp_setToolButtonEnabled(false,false,false);
    ui->listWidget->setEnabled(false);

    videoPos.X = 70;
    videoPos.Y = 0;
    signal_pc_key_set_displaypos(videoPos);//打开视频层前需要设置视频层位置
    Sleep(10);
    signal_pc_buf_start_encode();
}
//删除按钮
void hp_preview::on_toolButton_delete_clicked()
{
    hp_updateStatus(false);
    currentSelect = PREVIEW_Delete;
    hp_updateStatus(true);
    //    if(!ui->listWidget->currentItem())
    //        return;
    FormatDialog->hp_setFormatDialogText(tr("是否删除此项?"));
    FormatDialog->hp_setDialogType(DIALOG_OKCANCEL);
    FormatDialog->show();

}
//确定删除图片
void hp_preview::slot_delete_pic()
{
    QString deleteCmd;
    deleteCmd = "rm -f "+FileDirect+"/"+ui->listWidget->currentItem()->text();//先将当前的要删除的图片名称记录下来
    QByteArray ba=deleteCmd.toUtf8();
    system(ba);
    system("sync");
    QString ACTFileName;
    ACTFileName = "ACT_"+ui->listWidget->currentItem()->text().mid(4,15)+".act";
    deleteCmd = "rm -f "+FileDirect+"/"+ACTFileName;//先将当前的要删除的图片名称记录下来
    qDebug()<<deleteCmd;
    system(deleteCmd.toUtf8());
    system("sync");
    SlotSDInsert();
    hp_updateCurrentItemInfo(false);
    hp_setToolButtonEnabled(false,false,true);
}
