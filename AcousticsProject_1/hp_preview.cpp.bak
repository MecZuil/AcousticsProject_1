//显示视频第一帧
void hp_preview::ShowVideoFirstPic(int x,int y,int width,int height)
{
    ui->pictureShow->setGeometry(x,y,width,height);
    QString CurrentVidName = ui->listWidget->currentItem()->text().section('.',0,0);
    QString videoFirstJPG = "./res/TempStoragePng/" + CurrentVidName + ".jpg";
    qDebug()<<"hp_updateCurrentVidItemInfo----on_listWidget_currentRowChanged : videoFirstJPG_Path : "<<videoFirstJPG;
    if(! QFile::exists(videoFirstJPG) )
    {
        qDebug()<<"./res/TempStoragePng/+FileName+.jpg  not exists";
    }
    QImage *image = new QImage(videoFirstJPG);
    QPixmap *pixmap = new QPixmap();
    *image = image->scaled(width,height,Qt::IgnoreAspectRatio,Qt::SmoothTransformation);
    pixmap->convertFromImage(*image);
    ui->pictureShow->setPixmap(*pixmap);
    ui->pictureShow->show();
    ui->listWidget->raise();
}
//设置蓝牙连接状态
void hp_preview::hp_SetPreviewSaveBlu(int isConnected)
{
    isBluConnected = isConnected;
}
//设置按钮可使用状态
void hp_preview::hp_setToolButtonEnabled(int isEdit,int isDelete,int isReturn)
{
    ui->toolButton_edit->setEnabled(isEdit);
    ui->toolButton_delete->setEnabled(isDelete);
    ui->toolButton_close->setEnabled(isReturn);
}
//视频播放时间获取
void hp_preview::query_position_and_duration()
{
    qDebug() << __func__;
    gint64 position, duration;
    if (gst_element_query_position(pipeline, GST_FORMAT_TIME, &position) &&
            gst_element_query_duration(pipeline, GST_FORMAT_TIME, &duration)) {
        qDebug() << typeid(position).name() << position << duration;
        QString currTime = QString::number(position / 1000000000);
        QString totalTime = QString::number(duration / 1000000000);
        qDebug() << currTime.toInt() << totalTime.toInt() << currTime << totalTime;
        ui->slider_video_2->setMaximum(totalTime.toInt());
        ui->slider_video_2->setValue(currTime.toInt());
        //gint64是long long int类型，单位是纳秒，所以要除1000000000才是正常的秒数
        if(currTime.toInt() >= totalTime.toInt())
        {
            on_toolButton_videoStop_clicked();

        }
    }
}

void hp_preview::seekToPosition(gint64 time_nanoseconds)
{
    if (!pipeline) {
        qDebug() << "Pipeline is not initialized";
        return;
    }

    /*
        element: 进行seek操作的GstElement。
        rate: 播放速率，1.0 表示正常速率。
        format: 位置和时间的格式，通常是GST_FORMAT_TIME，表示时间以纳秒为单位。
        flags: 寻求行为的标志，例如GST_SEEK_FLAG_FLUSH（在seek前刷新管道）。
        start_type: 开始位置的类型，通常是GST_SEEK_TYPE_SET（从绝对位置开始）。
        start: 开始位置的具体值（如从视频的第几纳秒开始）。
        stop_type: 结束位置的类型，可以是GST_SEEK_TYPE_NONE（不指定结束位置）。
        stop: 具体的结束位置（如果stop_type不是GST_SEEK_TYPE_NONE）。
     */
    gboolean seek_success = gst_element_seek(pipeline,
                                             1.0,                // rate
                                             GST_FORMAT_TIME,    // format
                                             GST_SEEK_FLAG_FLUSH, // flags
                                             GST_SEEK_TYPE_SET,   // start_type
                                             time_nanoseconds,    // start
                                             GST_SEEK_TYPE_NONE,  // stop_type
                                             GST_CLOCK_TIME_NONE); // stop


    if (!seek_success) {
        qDebug() << "Seek operation failed";
    } else {
        qDebug() << "Seek operation succeeded";
    }
}

int hp_preview::getAudioSize(const QString fileName)
{
    QString filePath = "/run/media/mmcblk2p1/DCIM/" + fileName;
    QFile file(filePath);

    if (!file.open(QIODevice::ReadOnly)) {
        qDebug() << "Failed to open file:" << file.errorString();
        return 0;
    }

    // 设置偏移量到 264 字节处
    qint64 offset = 264;
    if (!file.seek(offset)) {
        qDebug() << "Failed to seek to offset" << offset;
        file.close();
        return 0;
    }

    QDataStream in(&file);
    in.setByteOrder(QDataStream::BigEndian);

    int value;
    in >> value;

    if (in.status() != QDataStream::Ok) {
        qDebug() << "Failed to read integer from file";
        file.close();
        return 1;
    }

    qDebug() << "Read value:" << value;
    qDebug("0x%x", value);

    file.close();

    return value;
}
//按键 ↓键
void hp_preview::KeyDownHandle()
{
    hp_updateStatus(false);
    if(ui->frame_pic->isVisible())//图片选中
    {
        if(currentSelect == PREVIEW_ListWidget)
        {
            currentSelect = PREVIEW_VoiceNote;
        }
        else if(currentSelect == PREVIEW_VoiceNote)
        {
            currentSelect = PREVIEW_Edit;
        }
    }
    else if(ui->frame_vid->isVisible())//视频选中
    {
        if(currentSelect == PREVIEW_ListWidget)
        {
            currentSelect = PREVIEW_VideoPlay;
        }
        else if(currentSelect == PREVIEW_VideoPlay)
        {
            currentSelect = PREVIEW_VideoStop;
        }
        else if(currentSelect == PREVIEW_VideoStop)
        {
            currentSelect = PREVIEW_Return;
        }
    }
    else//未选中或选中错误文件
    {
        if(currentSelect == PREVIEW_ListWidget)
        {
            currentSelect = PREVIEW_Return;
        }
    }
    hp_updateStatus(true);
}
//按键 ↑键
void hp_preview::KeyUpHandle()
{
    hp_updateStatus(false);
    if(ui->frame_pic->isVisible())//图片选中
    {
        if(currentSelect == PREVIEW_Edit||currentSelect == PREVIEW_Return||currentSelect == PREVIEW_Delete)
        {
            currentSelect = PREVIEW_VoiceNote;
        }
        else if(currentSelect == PREVIEW_VoiceNote)
        {
            if(ui->listWidget->currentItem()==nullptr&&ui->listWidget->count()!=0)
            {
                ui->listWidget->setCurrentRow(0);
                currentSelect = PREVIEW_ListWidget;
            }
            else if(ui->listWidget->currentItem()!=nullptr)
            {
                currentSelect = PREVIEW_ListWidget;
            }
        }
    }
    else if(ui->frame_vid->isVisible())//视频选中
    {
        if(currentSelect == PREVIEW_Return)
        {
            currentSelect = PREVIEW_VideoStop;
        }
        else if(currentSelect == PREVIEW_VideoStop)
        {
            currentSelect = PREVIEW_VideoPlay;
        }
        else if(currentSelect == PREVIEW_VideoPlay)
        {
            if(ui->listWidget->currentItem()==nullptr&&ui->listWidget->count()!=0)
            {
                ui->listWidget->setCurrentRow(0);
                currentSelect = PREVIEW_ListWidget;
            }
            else if(ui->listWidget->currentItem()!=nullptr)
            {
                currentSelect = PREVIEW_ListWidget;
            }
        }
    }
    else//未选中或选中错误文件
    {
        if(currentSelect == PREVIEW_Edit||currentSelect == PREVIEW_Return||currentSelect == PREVIEW_Delete)
        {
            currentSelect = PREVIEW_ListWidget;
        }
    }
    hp_updateStatus(true);
}
//按键 ←键
void hp_preview::KeyLeftHandle()
{
    hp_updateStatus(false);
    if(currentSelect == PREVIEW_Edit||(currentSelect == PREVIEW_Delete&&!ui->toolButton_delete->isEnabled()))
    {
        if(ui->listWidget->currentItem()==nullptr&&ui->listWidget->count()!=0)
        {
            ui->listWidget->setCurrentRow(0);
            currentSelect = PREVIEW_ListWidget;
        }
        else if(ui->listWidget->currentItem()!=nullptr)
        {
            currentSelect = PREVIEW_ListWidget;
        }
    }
    else if(currentSelect == PREVIEW_Edit&&ui->toolButton_delete->isEnabled())
    {
        currentSelect = PREVIEW_Edit;
    }
    else if(currentSelect == PREVIEW_Return)
    {
        if(ui->toolButton_delete->isEnabled())
        {
            currentSelect = PREVIEW_Delete;
        }
        else//删除若不可使用则编辑必也不可
        {
            if(ui->listWidget->currentItem()==nullptr&&ui->listWidget->count()!=0)
            {
                ui->listWidget->setCurrentRow(0);
                currentSelect = PREVIEW_ListWidget;
            }
            else if(ui->listWidget->currentItem()!=nullptr)
            {
                currentSelect = PREVIEW_ListWidget;
            }
        }
    }
    else if(currentSelect == PREVIEW_ListWidget)
    {
        if(ui->listWidget->currentItem()==nullptr&&ui->listWidget->count() != 0)
        {
            ui->listWidget->setCurrentRow(0);
        }
        else if((ui->listWidget->currentRow()-1)>=0)
        {
            ui->listWidget->setCurrentRow(ui->listWidget->currentRow()-1);
        }
    }
    hp_updateStatus(true);
}
//按键 →键
void hp_preview::KeyRightHandle()
{
    hp_updateStatus(false);
    if(currentSelect == PREVIEW_ListWidget)
    {
        if(ui->listWidget->currentItem()==nullptr&&ui->listWidget->count() != 0)
        {
            ui->listWidget->setCurrentRow(0);
        }
        else if((ui->listWidget->currentRow()+1)<ui->listWidget->count())
        {
            ui->listWidget->setCurrentRow(ui->listWidget->currentRow()+1);
        }
    }
    else if(currentSelect == PREVIEW_Edit)
    {
        currentSelect = PREVIEW_Delete;
    }
    else if(currentSelect == PREVIEW_Delete)
    {
        currentSelect = PREVIEW_Return;
    }
    hp_updateStatus(true);
}
//按键 确认键
void hp_preview::KeyOKHandle()
{
    switch (currentSelect) {
    case PREVIEW_Delete:
        if(ui->toolButton_delete->isEnabled())
        {
            emit ui->toolButton_delete->clicked();
        }
        break;
    case PREVIEW_Edit:
        if(ui->toolButton_edit->isEnabled())
        {
            emit ui->toolButton_edit->clicked();
        }
        break;
    case PREVIEW_ListWidget:
        break;
    case PREVIEW_Return:
        if(ui->toolButton_close->isEnabled())
        {
            emit ui->toolButton_close->clicked();
        }
        break;
    case PREVIEW_VideoPlay:
        emit ui->toolButton_videoPlay->clicked();
        break;
    case PREVIEW_VideoStop:
        emit ui->toolButton_videoStop->clicked();
        break;
    case PREVIEW_VoiceNote:
        emit ui->toolButton_voiceNotes->clicked();
        break;
    }
}
//按键 返回键
void hp_preview::KeyReturnHandle()
{
    if(ui->toolButton_close->isEnabled())
    {
        if(isVideoProcessStart)
        {
            on_toolButton_videoStop_clicked();
        }
        else
        {
            ui->toolButton_close->click();
        }
    }

}

//图片上传按钮响应
void hp_preview::on_toolButton_PicSave_clicked()
{
    SignalUpdateSetUpClock();
    if(isClientConnected)
    {
        ErrorWarningDialog->warning(tr("提示"),tr("图片上传中"));
        //    ErrorWarningDialog->setDelayClose(5000);
        ErrorWarningDialog->show();
        char * picName = ui->listWidget->currentItem()->text().toUtf8().data();
        signal_pc_pic_set_pic(picName);
    }
    else
    {
        ErrorWarningDialog->warning(tr("错误"),tr("请先进行客户端连接"));
        ErrorWarningDialog->setDelayClose(3000);
        ErrorWarningDialog->show();
    }
}
//图片上传信号反馈
void hp_preview::slot_pc_pic_set_pic(unsigned char return_value)
{
    if(return_value == RE_OK)
    {
        ErrorWarningDialog->warning(tr("提示"),tr("图片上传成功"));
    //    ErrorWarningDialog->setDelayClose(5000);
        ErrorWarningDialog->show();
    }
    else
    {
        ErrorWarningDialog->warning(tr("错误"),tr("图片上传失败"));
        ErrorWarningDialog->setDelayClose(5000);
        ErrorWarningDialog->show();
    }
}
//客户端连接传递
void hp_preview::SlotIsClientConnected(bool isConnected)
{
    isClientConnected = isConnected;
}
