void hp_preview::hp_updateStatus(bool isSelect)
{
    if(UIType == 1)
    {
        switch (currentSelect)
        {
        case PREVIEW_ListWidget:
            if(isSelect)
            {
                ui->listWidget->setStyleSheet(ListWidgetHorizontalSheetStyle_1920_s);
