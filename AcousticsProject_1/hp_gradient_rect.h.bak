#include <QWidget>
#include <QDebug>
#include <QPainter>
#include <QMouseEvent>
#include <QPainterPath>

#include "hp_enum.h"
#include "hi384_protocol.h"

namespace Ui {
class hp_gradient_rect;
}

class hp_gradient_rect : public QWidget
{
    Q_OBJECT

public:
    explicit hp_gradient_rect(QWidget *parent = nullptr);
    ~hp_gradient_rect();

    void hp_setMovingRangeUpper(int movingRangeUpper);
    void hp_setMovingRangeLower(int_move_range value);
    void hp_undateSliderUI(bool isSelect);



protected:
    virtual void paintEvent(QPaintEvent *ev) ;
    virtual bool eventFilter(QObject *obj, QEvent *event) ;

signals:
    void signal_pc_key_set_moving_range(int_move_range movingRange);
    void signal_pc_key_get_moving_range(int id);

    void SignalSetDynamicRange(int_move_range moving_range);
//    void SignalGradientRectPressed();

private slots:
    void on_verticalSlider_valueChanged(int value);

    void on_verticalSlider_sliderReleased();

    void on_verticalSlider_sliderPressed();

private:
    Ui::hp_gradient_rect *ui;

    int isPress;
    int movingRangeMaxValue;//记录动态范围最大值
    bool isSliderShow;
    int_move_range moving_range;
};

