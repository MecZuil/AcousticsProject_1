#include "hp_capture_save.h"
#include "ui_hp_capture_save.h"
#include "hp_input_text.h"

hp_capture_save::hp_capture_save(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_capture_save)
{
    ui->setupUi(this);
    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
    setWindowModality(Qt::WindowModal);

    hp_UIStatus_update(false);
    currentSelect =SAVE_NAME;
    hp_UIStatus_update(true);

    saveShow=CAPTURE_PIC_SAVE;
    isNormal=0;
    isUnkown=0;
    isPD=0;
    isGas=0;
    isCollect=0;
    TimerVoiceNoteCount= 0;//录制时长不超过20s
    hasVoiceNotes = false;
    isAudioStart=false;
    isBluConnected = false;
//    oldFileName = "";

    hp_winInit();
    hp_connectInit();
    ui->edit_notes->setText("");
    ui->label_error->close();
}

hp_capture_save::~hp_capture_save()
{
    delete ui;
}

void hp_capture_save::hp_winInit()
{
    TimerVoiceNote = new QTimer(this);
    TimerVoiceNote->setInterval(1000);
//    HpStatusBoxTop = new hp_statusbox_top(this);
//    HpStatusBoxTop->setGeometry(800-160,2,160,50);
    HpInputText = new hp_input_text(this);
    HpInputText->hp_setIns(INPUT_CAP_SAVE);
    HpInputText->hp_setMaxInput(40);
    HpInputText->close();
    ErrorWarning = new hp_errorwarning_dialog(this,tr("出错了"),tr("没有检测到SD卡"),0);
    ErrorWarning->move((this->width()-ErrorWarning->width())/2, (this->height()-ErrorWarning->height())/2);
    ErrorWarning->close();

    ui->frame_labelCheckBox->close();
    ui->label_voice_notes_time->close();

    ui->frame->installEventFilter(this);
    ui->preWidget->installEventFilter(this);
    ui->frame_background->installEventFilter(this);
    ui->toolButton_voice->installEventFilter(this);
    ui->edit_name->installEventFilter(this);
    ui->edit_notes->installEventFilter(this);
    //QTextEdit必须给控件和视图窗口都注册事件过滤器
}

void hp_capture_save::hp_connectInit()
{
    connect(HpInputText,SIGNAL(hp_signal_text_over(QString,INPUT_NOW_SHOW)),this,SLOT(hp_slot_text_over(QString,INPUT_NOW_SHOW)));
    connect(TimerVoiceNote,SIGNAL(timeout()),this,SLOT(SlotTimerVoiceNote()));
}

void hp_capture_save::changeEvent(QEvent *e)
{
    QWidget::changeEvent(e);
    switch(e->type())
    {
    case QEvent::LanguageChange:
        ui->retranslateUi(this);
        break;
    default:
        break;
    }
}

bool hp_capture_save::eventFilter(QObject *watched, QEvent *event)
{
    if(event->type()==QMouseEvent::MouseButtonRelease)
    {
//        if(!HpInputText->isHidden())
//        {
//            HpInputText->hide();
//        }
        //文本框点击事件
        qDebug()<<"hp_capture_save::eventFilter-------------QMouseEvent::MouseButtonRelease   objectName : "<<watched->objectName();
        if(watched->objectName() =="edit_notes")
        {
            hp_UIStatus_update(false);
            currentSelect = SAVE_NOTES;
            hp_UIStatus_update(true);
            hp_edit_clicked();
            return true;
        }
        else if(watched->objectName() =="edit_name")
        {
            hp_UIStatus_update(false);
            currentSelect = SAVE_NAME;
            hp_UIStatus_update(true);
            hp_edit_clicked();
            return true;
        }
    }
    return false;
}
void hp_capture_save::mousePressEvent(QMouseEvent *event)
{
    SignalUpdateSetUpClock();
}

void hp_capture_save::keyPressEvent(QKeyEvent *ev)
{
    if(!(isLongKey=ev->isAutoRepeat()))
    {
        qDebug(" mainwidget::keyPressEvent(QKeyEvent *ev)---------- ev->key() = 0x%02x",ev->key());
        SignalUpdateSetUpClock();
    }

}

void hp_capture_save::keyReleaseEvent(QKeyEvent *ev)
{
    qDebug(" mainwidget::keyReleaseEvent(QKeyEvent *ev)---------- ev->key() = 0x%02x",ev->key());
    SignalUpdateSetUpClock();
    switch (ev->key()) {
    case Key_RETURN:
        KeyReturnHandle();
        break;
    case Key_CAPTURNANDVIDEO:
        on_toolButton_save_clicked();
        break;
    case Qt::Key_O:
        SignalPrintscreenHandle();
        break;
    default:
        break;
    }
}

