#include "hp_dialog_hidepassword.h"
#include "ui_hp_dialog_hidepassword.h"

hp_dialog_hidepassword::hp_dialog_hidepassword(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_dialog_hidepassword)
{
    ui->setupUi(this);
    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
    setWindowModality(Qt::WindowModal);

    HpInputText = new hp_input_text(this);
    HpInputText->close();

    connect(HpInputText,SIGNAL(hp_signal_text_over(QString,INPUT_NOW_SHOW)),this,SLOT(hp_slot_text_over(QString,INPUT_NOW_SHOW)));

    ui->frame_Password->installEventFilter(this);

    UIType = 0;
    key_adjust = "jkph";
    key_calibration_ir = "hpkjca";
}

hp_dialog_hidepassword::~hp_dialog_hidepassword()
{
    delete ui;
}


void hp_dialog_hidepassword::changeEvent(QEvent *e)
{
    QWidget::changeEvent(e);
    switch(e->type())
    {
    case QEvent::LanguageChange:
        ui->retranslateUi(this);
        break;
    default:
        break;
    }
}

bool hp_dialog_hidepassword::eventFilter(QObject *obj, QEvent *event)
{
    if(event->type()==QMouseEvent::MouseButtonPress)
    {
        SignalUpdateSetUpClock();
        if(obj->objectName()=="frame_Password")
        {
            UIStatusUpdate(true,false);
            if(HpInputText->isHidden())
            {
                HpInputText->hp_setShow(INPUT_SHOW_ENG);
                HpInputText->hp_setMaxInput(40);
                HpInputText->hp_setText(ui->PasswordText->text());
                HpInputText->show();
            }
            else
            {
                HpInputText->hide();
            }

        }
    }
}

void hp_dialog_hidepassword::SlotSetUIStyle(int type)
{
    UIType = type;
    if(type==1)
    {
        this->setGeometry(0,0,1920,1080);
        ui->frame->setGeometry(0,0,1920,1080);
        ui->toolButton_close->setGeometry(0,0,0,0);
        ui->frame_Password->setGeometry(0,0,0,0);
        ui->PromptText->setGeometry(0,0,0,0);
        ui->PasswordText->setGeometry(0,0,0,0);
        ui->toolButton_enter->setGeometry(0,0,0,0);
        ui->toolButton_close->setStyleSheet(ToolButtonSheetStyle_1920_n);
        ui->toolButton_enter->setStyleSheet(ToolButtonSheetStyle_1920_n);
        ui->frame->setStyleSheet(FrameBackground_1_1920);
    }

}

void hp_dialog_hidepassword::UIStatusUpdate(bool isPasswordSelect,bool isButtonSelect)
{
    if(isPasswordSelect)
        ui->frame_Password->setStyleSheet(FrameSheetStyle_s);
    else
        ui->frame_Password->setStyleSheet(FrameSheetStyle_n);

    if(isButtonSelect)
        ui->toolButton_enter->setStyleSheet(ToolButtonSheetStyle_s);
    else
        ui->toolButton_enter->setStyleSheet(ToolButtonSheetStyle_n);
}

void hp_dialog_hidepassword::on_toolButton_enter_clicked()
{
    UIStatusUpdate(false,true);

    QString password = ui->PasswordText->text();
    if(password == key_adjust)
    {
        SignalHpHideInterfaceShow(1);
        on_toolButton_close_clicked();
    }
    else if(password == key_calibration_ir)
    {
        if(IRHZHPara.type !=1 && IRHZHPara.type != 0)
        {
            ui->PromptText->setText(tr("请打开红外相关模式"));
            ui->PromptText->show();
        }
        else
        {
            SignalHpHideInterfaceShow(2);
            on_toolButton_close_clicked();
        }

    }
    else {
        ui->PasswordText->clear();
        ui->PromptText->setText(tr("密码错误"));
        ui->PromptText->show();
    }
}

void hp_dialog_hidepassword::on_toolButton_close_clicked()
{
    this->close();
    UIStatusUpdate(false,false);
    ui->PasswordText->clear();
    ui->PromptText->setText(tr("请输入密码进入隐藏界面..."));
    ui->PromptText->show();
}

void hp_dialog_hidepassword::hp_slot_text_over(QString text,INPUT_NOW_SHOW nowShow)
{
    if(ui->PasswordText->isVisible())
    {
        ui->PasswordText->setVisible(false);
    }
    ui->PromptText->hide();
    ui->PasswordText->show();
    ui->PasswordText->setText(text);
    qDebug()<<"ui->wifiPassword_text_2->text()"<<ui->PasswordText->text();
    if(ui->PasswordText->text().isEmpty())
    {
        ui->PromptText->setText(tr("请输入密码进入隐藏界面..."));
        ui->PromptText->show();
    }

}
