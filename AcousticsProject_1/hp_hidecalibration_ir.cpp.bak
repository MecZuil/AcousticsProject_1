#include "hp_hidecalibration_ir.h"
#include "ui_hp_hidecalibration_ir.h"

hp_hidecalibration_ir::hp_hidecalibration_ir(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::hp_hidecalibration_ir)
{
    ui->setupUi(this);
    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
    setWindowModality(Qt::WindowModal);

    setGeometry(70,0,this->width(),this->height());
    ui->frame->setStyleSheet("QFrame{background-color:rgb(0,8,16);}");

    UIType = 0;
    isDrawPoint = false;
    PromptDialog = new hp_formatdialog(this);
    PromptDialog->hp_setFormatDialogText(tr("参数保存中..."));
    PromptDialog->hp_setDialogType(DIALOG_NULL);
    PromptDialog->close();

    HpInputText = new hp_input_text(this);
    HpInputText->hp_setIns(INPUT_HIDECALIIR);
    HpInputText->close();

    ui->listWidget_tempRange->close();

    connect(HpInputText,SIGNAL(hp_signal_text_over(QString,INPUT_NOW_SHOW)),this,SLOT(hp_slot_text_over(QString,INPUT_NOW_SHOW)));
    current_select = HIDECALIIR_EMISSIVITY;
    ui->label_coordinate_x->installEventFilter(this);
    ui->label_coordinate_y->installEventFilter(this);
    ui->spinBox_distance->installEventFilter(this);
    ui->spinBox_emissivity->installEventFilter(this);
    ui->spinBox_enviroTemp->installEventFilter(this);
    ui->spinBox_presetTemp1->installEventFilter(this);
    ui->frame_tempRange->installEventFilter(this);

    HpInputText->raise();
}

hp_hidecalibration_ir::~hp_hidecalibration_ir()
{
    delete ui;

